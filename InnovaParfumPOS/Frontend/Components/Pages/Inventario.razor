@page "/inventario"
@using InnovaParfumPOS.Backend.Services
@using InnovaParfumPOS.Backend.DTOs
@using InnovaParfumPOS.Backend.Models
@inject InnovaParfumPOS.Backend.Services.AppState AppState
@inject IProductService ProductService
@inject IExportService ExportService
@inject UserSession UserSession
@inject NavigationManager Navigation
@inject ToastService ToastService
@inject IJSRuntime JSRuntime

<PageTitle>Inventario - InnovaTec</PageTitle>

<div class="inv-container">
    <!-- Header del Módulo -->
    <div class="inv-header">
        <div class="inv-title-group">
            <h2>Inventario</h2>
            <p>Control de existencias y productos registrados</p>
        </div>
        <div class="inv-actions">
            <button class="btn btn-outline-secondary me-2 d-inline-flex align-items-center gap-2" @onclick="DownloadExcel">
                <i class="fas fa-file-excel"></i> Excel
            </button>
            <button class="btn btn-outline-danger me-2 d-inline-flex align-items-center gap-2" @onclick="DownloadPdf">
                <i class="fas fa-file-pdf"></i> PDF
            </button>
            <button class="btn btn-primary d-inline-flex align-items-center gap-2" @onclick="OpenRegisterModal">
                <i class="fas fa-plus"></i> Nuevo
            </button>
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="inv-kpi-grid">
        <div class="inv-kpi-card kpi-blue">
            <div class="kpi-icon">
                <i class="fas fa-boxes"></i>
            </div>
            <div class="kpi-info">
                <span class="kpi-label">Total Productos</span>
                <span class="kpi-value">@stats.TotalProductos</span>
            </div>
        </div>
        <div class="inv-kpi-card kpi-yellow">
            <div class="kpi-icon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <div class="kpi-info">
                <span class="kpi-label">Stock Bajo</span>
                <span class="kpi-value">@stats.StockBajo</span>
            </div>
        </div>
        <div class="inv-kpi-card kpi-red">
            <div class="kpi-icon">
                <i class="fas fa-times-circle"></i>
            </div>
            <div class="kpi-info">
                <span class="kpi-label">Sin Stock</span>
                <span class="kpi-value">@stats.SinStock</span>
            </div>
        </div>
        <div class="inv-kpi-card kpi-cyan">
            <div class="kpi-icon">
                <i class="fas fa-coins"></i>
            </div>
            <div class="kpi-info">
                <span class="kpi-label">Valorización</span>
                <span class="kpi-value">@AppState.CurrencySymbol @stats.Valorizacion.ToString("N2")</span>
            </div>
        </div>
    </div>

    <!-- Barra de Búsqueda y Filtros -->
    <div class="p-3 bg-white border rounded shadow-sm d-flex gap-3 align-items-center position-relative">
        <div class="position-relative flex-grow-1">
            <i class="fas fa-search position-absolute top-50 translate-middle-y text-muted ms-3"></i>
            <input type="text" class="form-control ps-5" placeholder="Buscar por nombre o código... (Presione Enter)" 
                   @bind="_filter.SearchTerm" @bind:event="oninput" @onkeyup="HandleKeyUp" />
        </div>
        
        <div class="dropdown">
            <button class="btn @(ActiveFilterCount > 0 ? "btn-primary" : "btn-outline-secondary") d-inline-flex align-items-center gap-2" type="button" @onclick="ToggleFilterMenu">
                <i class="fas fa-filter"></i> Filtros
                @if (ActiveFilterCount > 0)
                {
                    <span class="badge bg-white text-primary rounded-pill ms-1">@ActiveFilterCount</span>
                }
            </button>

            @if (showFilterMenu)
            {
                <div class="filter-dropdown-menu shadow-lg border rounded-3 p-3 position-absolute end-0 mt-2 bg-white" style="width: 420px; top: 100%; z-index: 1050;">
                    <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                        <h6 class="fw-bold mb-0 text-primary"><i class="fas fa-sliders-h me-2"></i>Filtros Avanzados</h6>
                        <button class="btn-close text-muted" @onclick="() => showFilterMenu = false"></button>
                    </div>

                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted mb-1">Estado</label>
                            <select class="form-select form-select-sm" @bind="_filter.ActivityStatus">
                                <option value="activos">Solo Activos</option>
                                <option value="inactivos">Solo Inactivos</option>
                                <option value="todos">Todos</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted mb-1">Stock</label>
                            <select class="form-select form-select-sm" @bind="_filter.StockStatus">
                                <option value="todos">Todos</option>
                                <option value="con_stock">Con Stock (>0)</option>
                                <option value="stock_bajo">Stock Bajo/Crítico</option>
                                <option value="sin_stock">Sin stock</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted mb-1">Categoría</label>
                            <select class="form-select form-select-sm" @bind="_filter.IdCategoria">
                                <option value="">Todas</option>
                                @foreach(var cat in categorias)
                                {
                                    <option value="@cat.IdCategoria">@cat.Nombre</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted mb-1">Origen / Tipo</label>
                            <select class="form-select form-select-sm" @bind="_filter.IdOrigen">
                                <option value="">Todos</option>
                                @foreach(var o in filterOrigenes)
                                {
                                    <option value="@o.IdOrigen">@o.Nombre</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted mb-1">Marca</label>
                            <select class="form-select form-select-sm" @bind="_filter.Marca">
                                <option value="">Todas</option>
                                @foreach(var m in filterMarcas)
                                {
                                    <option value="@m">@(char.ToUpper(m[0]) + m.Substring(1))</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted mb-1">Género</label>
                            <select class="form-select form-select-sm" @bind="_filter.IdGenero">
                                <option value="">Todos</option>
                                @foreach(var g in filterGeneros)
                                {
                                    <option value="@g.IdGenero">@g.DescGenero</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted mb-1">Vencimiento</label>
                            <div class="input-group input-group-sm mb-1">
                                <input type="number" class="form-control" @bind="_filter.ExpireInMonths" placeholder="Meses" min="1" max="120" disabled="@_filter.ShowExpiredOnly">
                            </div>
                            <div class="form-check form-check-sm">
                                <input class="form-check-input" type="checkbox" id="chkExpired" @bind="_filter.ShowExpiredOnly">
                                <label class="form-check-label text-danger small fw-bold" for="chkExpired">Vencidos</label>
                            </div>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted mb-1">ML</label>
                            <input type="number" step="any" class="form-control form-control-sm" @bind="_filter.Ml" placeholder="Ej. 100">
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                        <button class="btn btn-sm btn-link text-muted text-decoration-none px-0" @onclick="ClearFilters">Limpiar Todo</button>
                        <button class="btn btn-sm btn-primary rounded-pill px-4 fw-bold shadow-sm" @onclick="ApplyFilters">
                            <i class="fas fa-check me-2"></i>Aplicar Filtros
                        </button>
                    </div>
                </div>
            }
            
            <!-- Overlay para cerrar el menú haciendo clic afuera -->
            @if(showFilterMenu)
            {
                <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 2;" @onclick="() => showFilterMenu = false"></div>
            }
        </div>
    </div>

    <!-- Tabla de Productos -->
    <div class="inv-table">
        <table class="pos-table mb-0">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Tipo</th>
                    <th class="text-end">Precio Unit.</th>
                    <th class="text-center">Stock Actual</th>
                    <th class="text-end">Valor Total</th>
                    <th>Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (filteredProductos == null)
                {
                    <tr>
                        <td colspan="7" class="text-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="mt-2 text-muted">Cargando inventario...</p>
                        </td>
                    </tr>
                }
                else if (!filteredProductos.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-5">
                            <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
                            <p class="text-muted">No se encontraron productos.</p>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var prod in filteredProductos.Skip((currentPage - 1) * pageSize).Take(pageSize))
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="kpi-icon" style="width: 40px; height: 40px; font-size: 1rem; flex-shrink: 0;">
                                        <i class="fas fa-tag"></i>
                                    </div>
                                    <div style="min-width: 200px;">
                                        <span class="d-block fw-bold">@prod.Nombre</span>
                                        <small class="text-muted">@prod.Marca @prod.IdOrigenNavigation?.Nombre @prod.IdConcentracionNavigation?.Nombre</small>
                                        @if(prod.FechaVencimiento.HasValue)
                                        {
                                            <br><small class="text-danger" style="font-size: 0.75rem;"><i class="fas fa-calendar-alt"></i> Vence: @prod.FechaVencimiento.Value.ToString("dd/MM/yyyy")</small>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge-tipo @(prod.TipoProducto == "PERFUME" ? "badge-tipo-telefono" : "badge-tipo-accesorio")">
                                    @(prod.TipoProducto == "PERFUME" ? "Perfume" : "Artículo")
                                </span>
                            </td>
                            <td class="text-end fw-semibold">@AppState.CurrencySymbol @prod.(PrecioMinorista ?? 0).ToString("N2")</td>
                            <td class="text-center">
                                <div class="d-inline-block text-start">
                                    <span class="fw-bold fs-5">@prod.StockActual</span>
                                    <small class="text-muted">/ @prod.StockMinimo mín.</small>
                                    <div class="stock-bar-container">
                                        <div class="stock-bar @GetStockBarClass(prod)" style="width: @GetStockPercent(prod)%"></div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-end fw-bold">@AppState.CurrencySymbol @(((prod.PrecioMinorista ?? 0) * prod.StockActual).ToString("N2"))</td>
                            <td>
                                @if (!prod.Activo)
                                {
                                    <span class="badge-estado badge-estado-inactive">Desactivado</span>
                                }
                                else
                                {
                                    <span class="badge-estado @GetEstadoClass(prod)">
                                        @(prod.EstadoStock == "DISPONIBLE" ? "Disponible" : prod.EstadoStock == "CRITICO" ? "Crítico" : "Agotado")
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center">
                                    <button class="btn-action" title="Ajustar Stock" @onclick="() => OpenAdjustModal(prod)" disabled="@(!prod.Activo)" style="@(!prod.Activo ? "opacity: 0.5; cursor: not-allowed;" : "")">
                                        <i class="fas fa-exchange-alt"></i>
                                    </button>
                                    <button class="btn-action" title="Editar" @onclick="() => OpenEditModal(prod)">
                                        <i class="fas fa-pen"></i>
                                    </button>
                                    <button class="btn-action" title="Detalles" @onclick="() => OpenDetailModal(prod)">
                                        <i class="fas fa-info-circle"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Paginación Premium tipo Carrusel -->
    @if (productos != null && productos.Any())
    {
        var totalPages = (int)Math.Ceiling((double)productos.Count / pageSize);
        if (totalPages > 1)
        {
            <div class="pagination-container d-flex align-items-center p-3 border-top">
                <div class="flex-grow-1">
                    <span class="small text-muted">Mostrando @(Math.Min(productos.Count, (currentPage - 1) * pageSize + 1)) a @(Math.Min(productos.Count, currentPage * pageSize)) de @productos.Count productos</span>
                </div>
                <div class="pagination-carousel-container">
                    <ul class="pagination pagination-premium mb-0">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => SetPage(currentPage - 1)" title="Anterior">
                                <i class="fas fa-chevron-left"></i>
                            </button>
                        </li>
                        
                        @{
                            // Lógica de ventana deslizante (Carrusel de 6 números)
                            int maxVisible = 6;
                            int startPage = Math.Max(1, Math.Min(currentPage - 2, totalPages - maxVisible + 1));
                            int endPage = Math.Min(totalPages, startPage + maxVisible - 1);
                            
                            // Re-ajustar si estamos cerca del final
                            if (totalPages > maxVisible && endPage == totalPages) startPage = Math.Max(1, totalPages - maxVisible + 1);

                            for (int i = startPage; i <= endPage; i++)
                            {
                                var pageNum = i;
                                <li class="page-item @(currentPage == pageNum ? "active" : "") page-item-animated" @key="pageNum">
                                    <button class="page-link" @onclick="() => SetPage(pageNum)">@pageNum</button>
                                </li>
                            }

                            // Mostrar Elipsis y Última Página si es necesario
                            if (endPage < totalPages)
                            {
                                if (endPage < totalPages - 1)
                                {
                                    <li class="pagination-ellipsis">...</li>
                                }
                                <li class="page-item @(currentPage == totalPages ? "active" : "") page-item-animated">
                                    <button class="page-link" @onclick="() => SetPage(totalPages)">@totalPages</button>
                                </li>
                            }
                        }

                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => SetPage(currentPage + 1)" title="Siguiente">
                                <i class="fas fa-chevron-right"></i>
                            </button>
                        </li>
                    </ul>
                </div>
                <div class="flex-grow-1 text-end"></div> <!-- Espaciador para centrar el carrusel -->
            </div>
        }
    }
</div>

<!-- ============================================================ -->
<!-- MODALES (BOOTSTRAP ADAPTADO) -->
<!-- ============================================================ -->

<ProductRegisterForm @bind-IsVisible="showRegisterModal" Categorias="categorias" Generos="filterGeneros" Origenes="filterOrigenes" Concentraciones="filterConcentraciones" OnProductSaved="LoadData" />

@if (showEditModal && editingProduct != null)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 9999;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                <div class="modal-header bg-white border-0 p-4 pb-0">
                    <div class="d-flex align-items-center gap-3">
                        <div class="kpi-icon kpi-blue" style="width: 45px; height: 45px; background: rgba(52, 152, 219, 0.1); color: #3498db;">
                            <i class="fas fa-pen-nib"></i>
                        </div>
                        <div>
                            <h4 class="modal-title fw-bold mb-0">Editar Producto</h4>
                            <p class="text-primary small fw-bold mb-0">@editingProduct.Nombre</p>
                        </div>
                    </div>
                </div>
                <div class="modal-body p-4 pt-3">
                    <div class="row g-2">
                        <!-- Fila 1 -->
                        <div class="col-lg-3">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Código de Barras</label>
                            <div class="input-group-custom bg-light rounded-3 d-flex align-items-center px-2 py-1">
                                <i class="fas fa-barcode text-muted me-2 small"></i>
                                <input type="text" class="form-control bg-transparent border-0 py-1 shadow-none" @bind="editingProduct.CodigoBarras">
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Nombre</label>
                            <input type="text" class="form-control bg-light border-0 py-2 rounded-3 shadow-none" @bind="editingProduct.Nombre">
                        </div>
                        <div class="col-lg-3">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Categoría</label>
                            <select class="form-select bg-light border-0 py-1 rounded-3 shadow-none" @bind="editingProduct.IdCategoria" style="height: 38px;">
                                <option value="">Seleccione...</option>
                                @foreach (var cat in categorias)
                                {
                                    <option value="@cat.IdCategoria">@cat.Nombre</option>
                                }
                            </select>
                        </div>

                        <!-- Fila 2 -->
                        @if (categorias.FirstOrDefault(c => c.IdCategoria == editingProduct.IdCategoria)?.PedirMarca == true)
                          {
                              <div class="col-lg-3">
                                  <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Marca</label>
                                  <input type="text" class="form-control bg-light border-0 py-2 rounded-3 shadow-none" @bind="editingProduct.Marca">
                              </div>
                          }
                        @if (categorias.FirstOrDefault(c => c.IdCategoria == editingProduct.IdCategoria)?.PedirGenero == true)
                          {
                              <div class="col-lg-3">
                                  <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Género</label>
                                  <select class="form-select bg-light border-0 py-2 rounded-3 shadow-none" @bind="editingProduct.IdGenero"><option value="">Seleccione...</option>@foreach(var g in filterGeneros){<option value="@g.IdGenero">@g.DescGenero</option>}</select>
                              </div>
                          }
                        @if (categorias.FirstOrDefault(c => c.IdCategoria == editingProduct.IdCategoria)?.PedirOrigen == true)
                          {
                              <div class="col-lg-3">
                                  <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Origen / Tipo</label>
                                  <select class="form-select bg-light border-0 py-2 rounded-3 shadow-none" @bind="editingProduct.IdOrigen"><option value="">Seleccione...</option>@foreach(var o in filterOrigenes){<option value="@o.IdOrigen">@o.Nombre</option>}</select>
                              </div>
                          }
                        @if (categorias.FirstOrDefault(c => c.IdCategoria == editingProduct.IdCategoria)?.PedirConcentracion == true)
                          {
                              <div class="col-lg-3">
                                  <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Concentración</label>
                                  <select class="form-select bg-light border-0 py-2 rounded-3 shadow-none" @bind="editingProduct.IdConcentracion"><option value="">Seleccione...</option>@foreach(var c in filterConcentraciones){<option value="@c.IdConcentracion">@c.Nombre</option>}</select>
                              </div>
                          }
                        @if (categorias.FirstOrDefault(c => c.IdCategoria == editingProduct.IdCategoria)?.PedirVencimiento == true)
                          {
                              <div class="col-lg-3">
                                  <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Vencimiento</label>
                                  <input type="date" class="form-control bg-light border-0 py-2 rounded-3 shadow-none" @bind="editingProduct.FechaVencimiento">
                              </div>
                          }
                        @if (categorias.FirstOrDefault(c => c.IdCategoria == editingProduct.IdCategoria)?.PedirMl == true)
                          {
                              <div class="col-lg-3">
                                  <label class="form-label mb-1 fw-bold small text-muted text-uppercase">ML (Mililitros)</label>
                                  <input type="number" step="any" class="form-control bg-light border-0 py-2 rounded-3 shadow-none" placeholder="Ej. 100" @bind="editingProduct.Ml">
                              </div>
                          }

                        <!-- Fila 3 -->
                        <div class="col-lg-3">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Precio Compra</label>
                            <input type="number" class="form-control bg-light border-0 py-2 rounded-3 shadow-none" onfocus="this.select()" @bind="editingProduct.CostoProducto">
                        </div>
                        <div class="col-lg-3">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Precio Venta</label>
                            <input type="number" class="form-control bg-primary bg-opacity-10 border-0 py-2 rounded-3 shadow-none fw-bold text-primary" onfocus="this.select()" @bind="editingProduct.PrecioMinorista">
                        </div>
                        <div class="col-lg-3">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Stock Mínimo</label>
                            <input type="number" class="form-control bg-light border-0 py-2 rounded-3 shadow-none" onfocus="this.select()" @bind="editingProduct.StockMinimo">
                        </div>
                        <div class="col-lg-3 d-flex align-items-end">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" id="editSwitchChecked" @bind="editingProduct.Activo">
                                <label class="form-check-label fw-bold" for="editSwitchChecked">Producto Activo</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-2">
                    <button class="btn btn-link text-muted text-decoration-none px-4" @onclick="() => showEditModal = false">Cancelar</button>
                    <button class="btn btn-primary rounded-pill px-5 shadow fw-bold py-2" @onclick="HandleUpdateProduct">
                        <i class="fas fa-sync me-2"></i>Actualizar Datos
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (showAdjustModal && adjustingProduct != null)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(8px); position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 9999;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 450px;">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px; overflow: hidden;">
                <div class="modal-header border-0 bg-light p-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="kpi-icon kpi-blue shadow-sm" style="width: 45px; height: 45px; background: rgba(52, 152, 219, 0.1); color: #3498db;">
                            <i class="fas fa-exchange-alt"></i>
                        </div>
                        <div>
                            <h5 class="modal-title fw-bold mb-0">Ajuste de Stock</h5>
                            <p class="text-primary small fw-bold mb-0">@adjustingProduct.Nombre</p>
                        </div>
                    </div>
                </div>
                <div class="modal-body p-4 pt-3">
                    <div class="row g-3">
                        <!-- Sector de Valores -->
                        <div class="col-6">
                            <label class="form-label fw-bold small text-muted text-uppercase mb-1">Stock Actual</label>
                            <div class="bg-light p-2 px-3 rounded-3 border text-center">
                                <span class="fs-4 fw-bold text-muted">@adjustingProduct.StockActual</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-bold small text-muted text-uppercase mb-1">Cantidad a Ajustar</label>
                            <div class="input-group-custom bg-white border border-primary p-1 rounded-3 d-flex align-items-center px-2">
                                <input type="number" class="form-control border-0 bg-transparent fs-5 fw-bold text-primary shadow-none py-1 text-center" onfocus="this.select()" @bind="adjustQuantity" min="1">
                            </div>
                        </div>

                        <!-- Selector de Movimiento Horizontal -->
                        <div class="col-12 mt-2">
                            <label class="form-label fw-bold small text-muted text-uppercase mb-2">Tipo de Operación</label>
                            <div class="d-flex gap-2 p-1 bg-light rounded-pill border">
                                <button class="btn flex-grow-1 rounded-pill py-2 d-flex align-items-center justify-content-center gap-2 border-0 @(adjustType == "INGRESO" ? "btn-success shadow-sm" : "bg-transparent text-muted")" 
                                        @onclick='() => adjustType = "INGRESO"'>
                                    <i class="fas fa-plus-circle"></i> <span class="fw-bold small">INGRESO</span>
                                </button>
                                <button class="btn flex-grow-1 rounded-pill py-2 d-flex align-items-center justify-content-center gap-2 border-0 @(adjustType == "SALIDA" ? "btn-danger shadow-sm" : "bg-transparent text-muted")" 
                                        @onclick='() => adjustType = "SALIDA"'>
                                    <i class="fas fa-minus-circle"></i> <span class="fw-bold small">SALIDA</span>
                                </button>
                            </div>
                        </div>

                        <div class="col-12 mt-2">
                            <label class="form-label fw-bold small text-muted text-uppercase mb-1">Nota del Movimiento (Opcional)</label>
                            <input type="text" class="form-control bg-light border-0 py-2 rounded-3 shadow-none" placeholder="Ej: Error en conteo..." @bind="adjustObservation">
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-1">
                    <button class="btn btn-link text-muted text-decoration-none px-4" @onclick="CloseAdjustModal">Cancelar</button>
                    <button class="btn btn-primary rounded-pill px-5 shadow fw-bold py-2" @onclick="HandleAdjustStock">
                        <i class="fas fa-check-circle me-2"></i>Aplicar Ajuste
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (showDetailModal && selectedProduct != null)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(8px); position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 9999;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px; overflow: hidden; height: 82vh;">
                <div class="modal-header border-0 bg-white p-3 pb-1">
                    <div class="d-flex align-items-center justify-content-between w-100">
                        <div class="d-flex align-items-center gap-2">
                            <div class="kpi-icon kpi-cyan shadow-sm" style="width: 40px; height: 40px; font-size: 1.1rem;">
                                <i class="fas fa-file-invoice"></i>
                            </div>
                            <div>
                                <h5 class="modal-title fw-bold mb-0">Detalle del Producto</h5>
                                <p class="text-muted extra-small mb-0">Auditoría completa y Kardex de movimientos</p>
                            </div>
                        </div>
                        <div class="text-end">
                            <button class="btn btn-light rounded-circle shadow-sm border-0" @onclick="() => showDetailModal = false" style="width: 40px; height: 40px; transition: 0.3s;">
                                <i class="fas fa-times text-muted"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <div class="modal-body p-0 overflow-hidden text-dark d-flex flex-column" style="height: calc(100% - 65px);">
                    <div class="row g-0 h-100">
                        <!-- Sidebar: Datos Maestros -->
                        <div class="col-lg-3 border-end bg-light p-3 d-flex flex-column">
                            <div class="flex-grow-1 overflow-auto">
                                <div class="product-detail-card bg-white p-3 rounded-4 shadow-sm mb-3">
                                    <h6 class="fw-bold text-uppercase small text-muted mb-2 border-bottom pb-1">Datos Maestros</h6>
                                    <div class="mb-2">
                                        <label class="d-block extra-small text-muted mb-0">Nombre</label>
                                        <span class="fw-bold text-dark small d-block">@selectedProduct.Nombre</span>
                                    </div>
                                    <div class="mb-2">
                                        <label class="d-block extra-small text-muted mb-0">SKU / Código</label>
                                        <span class="item-code py-0 px-2" style="font-size: 0.75rem;">@(selectedProduct.CodigoBarras ?? "S/N")</span>
                                    </div>
                                    <div class="row g-2 mb-2">
                                        <div class="col-6">
                                            <label class="d-block extra-small text-muted mb-0">Marca</label>
                                            <span class="fw-semibold small">@selectedProduct.Marca</span>
                                        </div>
                                        <div class="col-6">
                                            <label class="d-block extra-small text-muted mb-0">Género</label>
                                            <span class="fw-semibold small">@selectedProduct.IdGeneroNavigation?.DescGenero</span>
                                        </div>
                                    </div>
                                    <div class="mb-1">
                                        <label class="d-block extra-small text-muted mb-0">Categoría</label>
                                        <span class="badge-tipo badge-tipo-articulo w-100 text-center py-1">
                                            @(selectedProduct.IdCategoriaNavigation?.Nombre ?? "S/C")
                                        </span>
                                    </div>
                                </div>

                                <div class="pricing-card bg-primary bg-opacity-10 p-3 rounded-4 border border-primary border-opacity-10">
                                    <h6 class="fw-bold text-primary text-uppercase extra-small mb-2">Finanzas</h6>
                                    <div class="d-flex justify-content-between mb-1">
                                        <span class="extra-small text-muted">Precio Venta</span>
                                        <span class="fw-bold text-primary small">@AppState.CurrencySymbol @selectedProduct.(PrecioMinorista ?? 0).ToString("N2")</span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-1">
                                        <span class="extra-small text-muted">Precio Compra</span>
                                        <span class="fw-semibold small">@AppState.CurrencySymbol @(selectedProduct.CostoProducto?.ToString("N2") ?? "0.00")</span>
                                    </div>
                                    <div class="border-top pt-1 mt-1 d-flex justify-content-between">
                                        <span class="extra-small fw-bold">Valor Total</span>
                                        <span class="fw-bold small">@AppState.CurrencySymbol @(((selectedProduct.PrecioMinorista ?? 0) * selectedProduct.StockActual).ToString("N2"))</span>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Conteo de Stock integrado en el fondo de la barra lateral -->
                            <div class="mt-auto pt-2 border-top">
                                <div class="bg-primary bg-opacity-10 rounded-4 p-2 text-center border border-primary border-opacity-10 shadow-sm">
                                    <span class="d-block fw-bold text-primary fs-4">@selectedProduct.StockActual</span>
                                    <span class="text-primary extra-small text-uppercase fw-bold letter-spacing-1">Existencias Totales</span>
                                </div>
                            </div>
                        </div>

                        <!-- Main Content: Kardex History -->
                        <div class="col-lg-9 d-flex flex-column bg-white">
                            <div class="flex-grow-1 overflow-auto p-4 pt-2">
                                <div class="d-flex align-items-center justify-content-between mb-3 mt-2">
                                    <h5 class="fw-bold mb-0"><i class="fas fa-history me-2 text-muted"></i>Movimientos de Inventario</h5>
                                    <span class="badge rounded-pill bg-light text-dark border">@productMovements.Count registros</span>
                                </div>

                                @if (productMovements == null || !productMovements.Any())
                                {
                                    <div class="text-center py-5 bg-light rounded-4 border border-dashed rounded">
                                        <i class="fas fa-layer-group fa-3x text-muted mb-3 opacity-50"></i>
                                        <p class="text-muted">Sin registros de movimientos.</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-hover align-middle">
                                            <thead class="bg-light sticky-top">
                                                <tr>
                                                    <th class="border-0 small text-uppercase text-muted ps-3">Fecha</th>
                                                    <th class="border-0 small text-uppercase text-muted">Operación</th>
                                                    <th class="border-0 small text-uppercase text-muted text-center">Cant.</th>
                                                    <th class="border-0 small text-uppercase text-muted text-center">Stock Final</th>
                                                    <th class="border-0 small text-uppercase text-muted">Referencia</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @{
                                                    var pagedMovements = productMovements
                                                        .Where(m => string.IsNullOrEmpty(selectedHistoryFilterType) || m.IdTipoMovNavigation?.Nombre == selectedHistoryFilterType)
                                                        .Skip((historyCurrentPage - 1) * historyPageSize)
                                                        .Take(historyPageSize)
                                                        .ToList();
                                                }
                                                @foreach (var mov in pagedMovements)
                                                {
                                                    <tr>
                                                        <td class="ps-3">
                                                            <div class="d-flex flex-column">
                                                                <span class="fw-semibold">@mov.FechaMov.ToString("dd/MM/yyyy")</span>
                                                                <small class="text-muted">@mov.FechaMov.ToString("hh:mm tt")</small>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            @{
                                                                var isPositive = mov.IdTipoMovNavigation.Signo == "+";
                                                                var badgeClass = isPositive ? "text-success bg-success bg-opacity-10" : "text-danger bg-danger bg-opacity-10";
                                                            }
                                                            <span class="badge @badgeClass rounded-pill px-3 py-2 fw-bold">
                                                                @mov.IdTipoMovNavigation.Nombre
                                                            </span>
                                                        </td>
                                                        <td class="text-center fw-bold @(isPositive ? "text-success" : "text-danger")">
                                                            @(isPositive ? "+" : "-") @mov.Cantidad
                                                        </td>
                                                        <td class="text-center">
                                                            <span class="fw-bold">@mov.StockDespues</span>
                                                        </td>
                                                        <td>
                                                            <div class="d-flex flex-column text-dark">
                                                                <span class="fw-medium small">@(mov.RegistradoPorNavigation?.Username ?? "Sistema")</span>
                                                                <small class="text-muted text-truncate" style="max-width: 250px;">
                                                                    @(mov.Observacion ?? "...")
                                                                </small>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                    
                                    @if (productMovements.Count > historyPageSize)
                                    {
                                        var totalHistoryPages = (int)Math.Ceiling((double)productMovements.Count / historyPageSize);
                                        <div class="d-flex justify-content-center mt-3">
                                            <nav>
                                                <ul class="pagination pagination-sm pagination-premium mb-0">
                                                    <li class="page-item @(historyCurrentPage == 1 ? "disabled" : "")">
                                                        <button class="page-link" @onclick="() => SetHistoryPage(historyCurrentPage - 1)">
                                                            <i class="fas fa-chevron-left"></i>
                                                        </button>
                                                    </li>
                                                    
                                                    @for (int i = 1; i <= totalHistoryPages; i++)
                                                    {
                                                        var pageNum = i;
                                                        <li class="page-item @(historyCurrentPage == pageNum ? "active" : "")">
                                                            <button class="page-link" @onclick="() => SetHistoryPage(pageNum)">@pageNum</button>
                                                        </li>
                                                    }
                                                    
                                                    <li class="page-item @(historyCurrentPage == totalHistoryPages ? "disabled" : "")">
                                                        <button class="page-link" @onclick="() => SetHistoryPage(historyCurrentPage + 1)">
                                                            <i class="fas fa-chevron-right"></i>
                                                        </button>
                                                    </li>
                                                </ul>
                                            </nav>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
}

@code {
    private List<Producto>? productos;
    private List<Producto>? filteredProductos; // Ahora será igual a productos (filtrado en BD)
    private List<Categoria> categorias = new();
    private InventoryStatsDto stats = new();
    
    // Filtros
    private ProductFilterDto _filter = new();
    private bool showFilterMenu = false;
    private List<string> filterMarcas = new();
    private List<Genero> filterGeneros = new();
    private List<Origen> filterOrigenes = new();
    private List<Concentracion> filterConcentraciones = new();
    
    
    private string? selectedHistoryFilterType = null;

    private int currentPage = 1;
    private int pageSize = 10;
    private System.Timers.Timer? debounceTimer;

    private int ActiveFilterCount 
    {
        get 
        {
            int count = 0;
            if (_filter.ActivityStatus != "activos") count++;
            if (_filter.StockStatus != "todos") count++;
            if (_filter.IdCategoria.HasValue && _filter.IdCategoria > 0) count++;
            if (_filter.ExpireInMonths.HasValue || _filter.ShowExpiredOnly) count++;
            if (!string.IsNullOrEmpty(_filter.Marca)) count++;
            if (_filter.IdGenero.HasValue && _filter.IdGenero > 0) count++;
            if (_filter.IdOrigen.HasValue && _filter.IdOrigen > 0) count++;
            if (_filter.Ml.HasValue) count++;
            return count;
        }
    }

    // Modal state
    private bool showRegisterModal = false;
    private bool showEditModal = false;
    private bool showAdjustModal = false;
    private bool showDetailModal = false;
    
    // Form data
    private Producto? editingProduct;
    private Producto? adjustingProduct;
    private Producto? selectedProduct;
    private List<Movimiento> productMovements = new();
    
    // History Pagination
    private int historyCurrentPage = 1;
    private int historyPageSize = 5;
    
    private string adjustType = "INGRESO"; // INGRESO or SALIDA
    private int adjustQuantity = 1;
    private string adjustObservation = "";

    protected override async Task OnInitializedAsync()
    {
        // Redireccionar si no hay sesión (Simulado para este ejemplo)
        if (!UserSession.IsAuthenticated)
        {
            // Navigation.NavigateTo("/login"); 
        }

        debounceTimer = new System.Timers.Timer(300);
        debounceTimer.AutoReset = false;
        debounceTimer.Elapsed += async (s, e) => await InvokeAsync(async () => await HandleSearch());
        
        categorias = await ProductService.GetCategoriasAsync();
        filterMarcas = await ProductService.GetDistinctMarcasAsync();
        filterGeneros = await ProductService.GetGenerosAsync();
        filterOrigenes = await ProductService.GetOrigenesAsync();
        filterConcentraciones = await ProductService.GetConcentracionesAsync();
        filterOrigenes = await ProductService.GetOrigenesAsync();

        await LoadData();

        // Alerta proactiva de productos agotados
        if (filteredProductos != null)
        {
            var agotados = filteredProductos.Where(p => p.StockActual <= 0).Select(p => p.Nombre).ToList();
            if (agotados.Any())
            {
                string nombres = agotados.Count > 3 
                    ? string.Join(", ", agotados.Take(3)) + $" y {agotados.Count - 3} más" 
                    : string.Join(", ", agotados);
                ToastService.ShowWarning($"{nombres} se encuentran sin stock actualmente.");
            }
        }
    }

    private void OpenRegisterModal()
    {
        showRegisterModal = true;
        StateHasChanged();
    }

    private void OpenEditModal(Producto p)
    {
        editingProduct = new Producto {
            IdProducto = p.IdProducto,
            Nombre = p.Nombre,
            Marca = p.Marca,
            IdGenero = p.IdGenero,
            PrecioMinorista = p.PrecioMinorista,
            StockActual = p.StockActual,
            StockMinimo = p.StockMinimo,
            Activo = p.Activo,
            IdCategoria = p.IdCategoria,
            CodigoBarras = p.CodigoBarras,
            IdOrigen = p.IdOrigen,
            IdConcentracion = p.IdConcentracion,
            FechaVencimiento = p.FechaVencimiento,
            Ml = p.Ml.HasValue && p.Ml.Value % 1 == 0 ? Math.Truncate(p.Ml.Value) : p.Ml,
            CostoProducto = p.CostoProducto
        };
        showEditModal = true;
        StateHasChanged();
    }

    private async Task HandleUpdateProduct()
    {
        if (editingProduct == null) return;
        
        if (string.IsNullOrWhiteSpace(editingProduct.Nombre))
        {
            ToastService.ShowWarning("El nombre del producto es obligatorio.");
            return;
        }

        if (editingProduct.IdCategoria == null || editingProduct.IdCategoria == 0)
        {
            ToastService.ShowWarning("Debe seleccionar una categoría para el producto.");
            return;
        }

        if (editingProduct.PrecioMinorista <= 0)
        {
            ToastService.ShowWarning("El precio de venta debe ser mayor a 0.");
            return;
        }

        var selectedCat = categorias.FirstOrDefault(c => c.IdCategoria == editingProduct.IdCategoria);
        if (selectedCat != null)
        {
            if (selectedCat.Nombre != null && selectedCat.Nombre.Contains("PERFUME", StringComparison.OrdinalIgnoreCase))
                editingProduct.TipoProducto = "PERFUME";
            else
                editingProduct.TipoProducto = "ARTICULO_VARIO";
        }
        
        try 
        {
            // La normalización de barcode y asignación de TipoProducto se hace ahora en el SP INV.sp_MantenerProducto
            await ProductService.UpdateProductAsync(editingProduct);
            ToastService.ShowSuccess("Los cambios se guardaron correctamente");
            showEditModal = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating product: {ex.Message}");
            ToastService.ShowError($"No se pudieron guardar los cambios: {ex.Message}");
        }
    }

    private void OpenAdjustModal(Producto p)
    {
        adjustingProduct = p;
        adjustType = "INGRESO";
        adjustQuantity = 1;
        adjustObservation = "";
        showAdjustModal = true;
        StateHasChanged();
    }

    private void CloseAdjustModal() => showAdjustModal = false;

    private async Task OpenDetailModal(Producto p)
    {
        selectedProduct = p;
        historyCurrentPage = 1; // Reset to page 1
        productMovements = await ProductService.GetProductMovementsAsync(p.IdProducto);
        showDetailModal = true;
        StateHasChanged();
    }

    private void SetHistoryPage(int page)
    {
        historyCurrentPage = page;
        StateHasChanged();
    }

    private async Task DownloadExcel()
    {
        try
        {
            var bytes = ExportService.GenerateInventoryExcel(productos ?? new List<Producto>());
            var stream = new MemoryStream(bytes);
            using var streamRef = new DotNetStreamReference(stream);
            await JSRuntime.InvokeVoidAsync("downloadFileFromStream", $"Inventario_{DateTime.Now:ddMMyy}.xlsx", streamRef);
            ToastService.ShowSuccess("Archivo Excel generado con éxito");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Error al generar Excel: " + ex.Message);
        }
    }

    private async Task DownloadPdf()
    {
        try
        {
            var bytes = await ExportService.GenerateInventoryPdfAsync(productos ?? new List<Producto>());
            var stream = new MemoryStream(bytes);
            using var streamRef = new DotNetStreamReference(stream);
            await JSRuntime.InvokeVoidAsync("downloadFileFromStream", $"Inventario_{DateTime.Now:ddMMyy}.pdf", streamRef);
            ToastService.ShowSuccess("Reporte PDF generado con éxito");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Error al generar PDF: " + ex.Message);
        }
    }

    private async Task HandleAdjustStock()
    {
        if (adjustingProduct == null || adjustQuantity <= 0) return;

        if (adjustType == "SALIDA" && adjustQuantity > adjustingProduct.StockActual)
        {
            ToastService.ShowError("La cantidad de salida es mayor al stock actual");
            return;
        }

        try 
        {
            int nuevaCantidad = adjustType == "INGRESO" 
                ? adjustingProduct.StockActual + adjustQuantity 
                : adjustingProduct.StockActual - adjustQuantity;

            string obsPrefix = adjustType == "INGRESO" ? "[AJUSTE ENTRADA]" : "[AJUSTE SALIDA]";
            string fullObs = $"{obsPrefix} {adjustObservation}".Trim();

            await ProductService.AdjustStockAsync(adjustingProduct.IdProducto, nuevaCantidad, fullObs);
            ToastService.ShowSuccess($"Inventario actualizado correctamente para {adjustingProduct.Nombre}");
            
            showAdjustModal = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error al ajustar stock: {ex.Message}");
        }
    }

    private async Task LoadData()
    {
        currentPage = 1;
        // Stats could be adapted to filter later if needed.
        stats = await ProductService.GetInventoryStatsAsync(_filter.SearchTerm, _filter.IdCategoria);
        productos = await ProductService.GetFilteredProductsAsync(_filter);
        filteredProductos = productos;
        await InvokeAsync(StateHasChanged);
    }

    private void ToggleFilterMenu() => showFilterMenu = !showFilterMenu;

    private async Task ApplyFilters()
    {
        showFilterMenu = false;
        await LoadData();
    }

    private async Task ClearFilters()
    {
        _filter = new ProductFilterDto();
        showFilterMenu = false;
        await LoadData();
    }

    private void HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            debounceTimer?.Stop();
            _ = HandleSearch();
        }
        else
        {
            debounceTimer?.Stop();
            debounceTimer?.Start();
        }
    }

    private async Task HandleSearch()
    {
        await LoadData();
    }

    private void SetPage(int page)
    {
        currentPage = page;
        StateHasChanged();
    }

    private string GetEstadoClass(Producto p) => p.EstadoStock switch {
        "DISPONIBLE" => "badge-estado-disp",
        "CRITICO" => "badge-estado-crit",
        "AGOTADO" => "badge-estado-agot",
        _ => ""
    };

    private string GetStockBarClass(Producto p) => p.EstadoStock switch {
        "DISPONIBLE" => "stock-bar-green",
        "CRITICO" => "stock-bar-yellow",
        "AGOTADO" => "stock-bar-red",
        _ => ""
    };

    private double GetStockPercent(Producto p) {
        if (p.StockActual <= 0) return 0;
        if (p.StockActual >= p.StockMinimo * 2) return 100;
        return (double)p.StockActual / (p.StockMinimo * 2) * 100;
    }

    public void Dispose()
    {
        debounceTimer?.Stop();
        debounceTimer?.Dispose();
    }
}

