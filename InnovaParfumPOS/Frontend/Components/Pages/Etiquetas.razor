@page "/etiquetas"
@using InnovaParfumPOS.Backend.Models
@using InnovaParfumPOS.Backend.Services
@using InnovaParfumPOS.Frontend.Components.UI
@inject InnovaParfumPOS.Backend.Services.AppState AppState
@inject IProductService ProductService
@inject UserSession Session
@inject NavigationManager Navigation
@inject ToastService Toast
@inject IJSRuntime JS
@inject ILabelService LabelService

<div class="etiquetas-premium-container animate__animated animate__fadeIn">
    <!-- Header Refinado -->
    <div class="etiquetas-header-glass">
        <div class="header-left">
            <div class="brand-icon">
                <i class="fas fa-barcode"></i>
            </div>
            <div class="header-titles">
                <h1>Gestión de Etiquetas</h1>
                <p>Genera y asocia códigos de barras para optimizar tu facturación</p>
            </div>
        </div>
        <div class="header-right">
            <button class="btn-premium-action" @onclick="() => showNewProductModal = true">
                <i class="fas fa-plus-circle me-2"></i> Nuevo Producto
            </button>
        </div>
    </div>

    <div class="etiquetas-workspace">
        <!-- Panel Izquierdo: Generador -->
        <div class="workspace-panel panel-generator">
            <div class="panel-card shadow-premium">
                <div class="panel-header">
                    <h3><i class="fas fa-magic me-2"></i> Generador de Código</h3>
                </div>
                <div class="panel-body text-center">
                    <div class="barcode-preview-area mx-auto">
                        @if (!string.IsNullOrEmpty(generatedBarcode))
                        {
                            <div class="barcode-visual mx-auto">
                                <svg id="barcode-canvas" style="width: 100%; max-height: 140px;"></svg>
                                <span class="barcode-number">@generatedBarcode</span>
                            </div>
                        }
                        else
                        {
                            <div class="barcode-placeholder">
                                <i class="fas fa-qrcode mb-2"></i>
                                <span>Presiona generar para comenzar</span>
                            </div>
                        }
                    </div>

                    <div class="generator-controls d-flex gap-2 justify-content-center align-items-end mt-2">
                        <div class="input-group-premium" style="max-width: 150px;">
                            <label class="d-block mb-1 small fw-bold text-muted text-uppercase" style="font-size: 0.7rem;">Código Manual</label>
                            <input type="text" class="form-control form-control-sm text-center fw-bold" @bind="generatedBarcode" @bind:after="UpdateBarcode" placeholder="Escribir..." />
                        </div>
                        <button class="btn btn-primary py-1 px-3 rounded shadow-sm fw-bold" style="height: 31px;" @onclick="GenerateCode">
                            <i class="fas fa-sync-alt me-1"></i> Generar
                        </button>
                    </div>
                </div>
                <div class="panel-footer bg-light border-top-0 pt-0 pb-3">
                    <div class="alert alert-info py-2 px-3 rounded-4 small mb-0 border-0 mx-auto" style="max-width: 320px; font-size: 0.75rem;">
                        <i class="fas fa-info-circle me-1"></i> Genera un código único para asociarlo a un producto.
                    </div>
                </div>
            </div>
        </div>

        <!-- Panel Central: Asociación -->
        <div class="workspace-panel panel-association">
            <div class="panel-card shadow-premium">
                <div class="panel-header">
                    <h3><i class="fas fa-link me-2"></i> Vincular con Producto</h3>
                </div>
                <div class="panel-body">
                    <div class="search-box-premium mb-2" style="max-width: 400px;">
                        <i class="fas fa-search search-icon"></i>
                        <input type="text" class="search-input" placeholder="Buscar producto..." 
                               @bind="searchTerm" @bind:event="oninput" @onkeyup="HandleSearch" />
                    </div>

                    <div class="product-selection-list custom-scrollbar mx-auto w-100" style="max-height: 180px;">
                        @if (isSearching)
                        {
                            <div class="text-center py-4">
                                <div class="spinner-border text-primary spinner-border-sm" role="status"></div>
                            </div>
                        }
                        else if (!PagedResults.Any())
                        {
                            <div class="empty-results py-4 text-center">
                                <i class="fas fa-box-open text-muted opacity-30"></i>
                                <p class="text-muted small">Sin resultados.</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var prod in PagedResults)
                            {
                                <div class="product-item @(selectedProduct?.IdProducto == prod.IdProducto ? "selected" : "")" 
                                     @onclick="() => SelectProduct(prod)">
                                    <div class="product-info d-flex flex-column align-items-start">
                                        <span class="product-name mb-0">@prod.Nombre</span>
                                        <span class="product-meta opacity-75">@(prod.Marca ?? "") | @(prod.CodigoBarras ?? "Sin Código")</span>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                        <div class="pagination-container d-flex align-items-center p-2 border-top w-100">
                            <div class="pagination-carousel-container">
                                <ul class="pagination pagination-premium mb-0">
                                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                        <button class="page-link py-1" @onclick="() => SetPage(currentPage - 1)">
                                            <i class="fas fa-chevron-left"></i>
                                        </button>
                                    </li>
                                    @{
                                        int maxVisible = 4;
                                        int startPage = Math.Max(1, Math.Min(currentPage - 1, TotalPages - maxVisible + 1));
                                        int endPage = Math.Min(TotalPages, startPage + maxVisible - 1);
                                        for (int i = startPage; i <= endPage; i++)
                                        {
                                            var pageNum = i;
                                            <li class="page-item @(currentPage == pageNum ? "active" : "")" @key="pageNum">
                                                <button class="page-link py-1" @onclick="() => SetPage(pageNum)">@pageNum</button>
                                            </li>
                                        }
                                    }
                                    <li class="page-item @(currentPage == TotalPages ? "disabled" : "")">
                                        <button class="page-link py-1" @onclick="() => SetPage(currentPage + 1)">
                                            <i class="fas fa-chevron-right"></i>
                                        </button>
                                    </li>
                                </ul>
                            </div>
                        </div>
                </div>
                <div class="panel-footer bg-light border-top-0 pt-0 pb-3 text-center">
                    <button class="btn btn-primary btn-sm w-100 rounded-pill fw-bold shadow" 
                            disabled="@(!CanAssociate)" @onclick="AssociateCode">
                        <i class="fas fa-check-circle me-1"></i> ASOCIAR
                    </button>
                </div>
            </div>
        </div>

        <!-- TERCER PANEL: IMPRESIÓN -->
        <div class="workspace-panel panel-print">
            <div class="panel-card shadow-premium border-primary-subtle">
                <div class="panel-header bg-primary text-white py-1" style="border-radius: 20px 20px 0 0;">
                    <h3 class="text-white"><i class="fas fa-print me-2"></i> Imprimir Etiquetas</h3>
                </div>
                <div class="panel-body custom-scrollbar">
                    <div class="print-panel-controls mb-2">
                        <div class="row g-2">
                            <div class="col-6 print-control-group">
                                <label style="font-size: 0.75rem;"><i class="fas fa-print me-1"></i> Impresora</label>
                                @if (string.IsNullOrEmpty(AppState.PrinterName))
                                {
                                    <div class="form-control form-control-sm bg-light text-danger fw-bold rounded-3 d-flex align-items-center" style="font-size: 0.75rem;">
                                        <i class="fas fa-exclamation-circle me-1"></i> Sin impresora
                                    </div>
                                }
                                else
                                {
                                    <div class="form-control form-control-sm bg-light text-primary fw-bold rounded-3 d-flex align-items-center text-truncate" style="font-size: 0.75rem;">
                                        <i class="fas fa-print me-1"></i> @AppState.PrinterName
                                    </div>
                                }
                            </div>
                            
                            <div class="col-6 print-control-group">
                                <label style="font-size: 0.75rem;"><i class="fas fa-layer-group me-1"></i> Plantilla</label>
                                <select class="form-select form-select-sm rounded-3" @bind="selectedTemplate" @bind:after="UpdatePrintPreview" style="font-size: 0.75rem;">
                                    <option value="mini">Mini (80x20mm)</option>
                                    <option value="mediana">Mediana (80x30mm)</option>
                                    <option value="grande">Grande (80x35mm)</option>
                                </select>
                            </div>
                        </div>

                        <div class="print-control-group mt-2">
                            <div class="search-box-premium" style="width: 100%;">
                                <input type="text" class="form-control form-control-sm rounded-3" placeholder="Buscar producto..." 
                                       @bind="printSearchTerm" @bind:event="oninput" @onkeyup="HandlePrintSearch" />
                            </div>
                        </div>

                        @if (printSearchResults.Any())
                        {
                            <div class="print-search-dropdown shadow-sm rounded-3 border mt-1">
                                @foreach (var prod in printSearchResults)
                                {
                                    <div class="print-search-item p-2 border-bottom @(printSelectedProduct?.IdProducto == prod.IdProducto ? "bg-primary-subtle" : "")" 
                                         @onclick="async () => await SelectPrintProduct(prod)">
                                        <div class="small fw-bold">@prod.Nombre</div>
                                        <div class="smaller text-muted">@(prod.CodigoBarras ?? "Sin Código") | @AppState.CurrencySymbol @prod.PrecioVenta:N2</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <!-- Preview Area -->
                    <div class="label-template-container mb-2">
                        @if (printSelectedProduct != null)
                        {
                            <div class="label-preview-box label-preview-@selectedTemplate" id="label-preview-render">
                                <p class="label-product-name">@printSelectedProduct.Nombre</p>
                                
                                @if (selectedTemplate == "grande")
                                {
                                    <p class="label-product-meta">
                                        @(printSelectedProduct.IdGeneroNavigation?.DescGenero ?? "N/A") | @(printSelectedProduct.IdConcentracionNavigation?.Nombre ?? "N/A")
                                    </p>
                                }

                                @if (selectedTemplate != "mini")
                                {
                                    <div class="label-price-container">
                                        @if (selectedTemplate == "grande") { <span class="label-price-label">Precio:</span> }
                                        <span class="label-price-value">@AppState.CurrencySymbol @printSelectedProduct.PrecioVenta.ToString("N2")</span>
                                    </div>
                                }

                                @if (!string.IsNullOrEmpty(printSelectedProduct.CodigoBarras))
                                {
                                    <svg class="label-barcode-svg" id="print-barcode-canvas"></svg>
                                    <span style="font-size: 7pt; font-family: monospace;">@printSelectedProduct.CodigoBarras</span>
                                }
                                else
                                {
                                    <div class="alert alert-warning py-1 px-2 small mt-2">Sin código de barras</div>
                                }

                                @if (selectedTemplate == "grande")
                                {
                                    <div class="label-footer">
                                        <span>InnovaTec POS</span>
                                        <span>@DateTime.Now.ToString("dd/MM/yyyy")</span>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center text-muted opacity-50">
                                <i class="fas fa-eye fa-2x mb-2"></i>
                                <p class="small">Selecciona un producto para previsualizar</p>
                            </div>
                        }
                    </div>

                    <div class="d-flex gap-2 align-items-end mt-2 border-top pt-2">
                        <div class="print-control-group flex-grow-1" style="max-width: 100px;">
                            <label style="font-size: 0.75rem;"><i class="fas fa-sort-numeric-up me-1"></i> Cantidad</label>
                            <input type="number" class="form-control form-control-sm text-center fw-bold" @bind="printQuantity" min="1" max="100" />
                        </div>

                        <button class="btn btn-primary btn-sm flex-grow-1 fw-bold rounded shadow-sm" style="height: 31px;" disabled="@(printSelectedProduct == null || string.IsNullOrEmpty(AppState.PrinterName))" @onclick="ExecutePrint">
                            @if (isPrinting)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Procesando...</span>
                            }
                            else
                            {
                                <i class="fas fa-print me-1"></i> <span>IMPRIMIR</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<ProductRegisterForm @bind-IsVisible="showNewProductModal" Categorias="categorias" InitialBarcode="@generatedBarcode" OnProductSaved="HandleNewProductSaved" />

