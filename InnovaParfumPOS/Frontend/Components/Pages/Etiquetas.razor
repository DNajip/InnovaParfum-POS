</style>

@code {
    private string generatedBarcode = "";
    private string searchTerm = "";
    private List<Producto> searchResults = new();
    private List<Categoria> categorias = new();
    private Producto? selectedProduct;
    private bool isSearching = false;
    private bool showNewProductModal = false;
    private int currentPage = 1;
    private int pageSize = 5;

    // Estados de Impresión
    private string selectedTemplate = "mini";
    private int printQuantity = 1;
    private string printSearchTerm = "";
    private List<Producto> printSearchResults = new();
    private Producto? printSelectedProduct;
    private bool isPrinting = false;

    private IEnumerable<Producto> PagedResults => searchResults
        .OrderByDescending(p => p.IdProducto)
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize);

    private int TotalPages => (int)Math.Ceiling((double)searchResults.Count / pageSize);

    private bool CanAssociate => !string.IsNullOrEmpty(generatedBarcode) && selectedProduct != null;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/");
            return;
        }

        categorias = await ProductService.GetCategoriasAsync();
        // Cargar productos iniciales sin código de barras para facilitar el uso
        var allProds = await ProductService.SearchProductsAsync("");
        searchResults = allProds.Where(p => string.IsNullOrEmpty(p.CodigoBarras)).ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!string.IsNullOrEmpty(generatedBarcode))
        {
            await JS.InvokeVoidAsync("generateBarcode", "barcode-canvas", generatedBarcode);
        }

        if (printSelectedProduct != null && !string.IsNullOrEmpty(printSelectedProduct.CodigoBarras))
        {
            await JS.InvokeVoidAsync("generateBarcode", "print-barcode-canvas", printSelectedProduct.CodigoBarras);
        }
    }

    private async Task UpdateBarcode()
    {
        if (!string.IsNullOrEmpty(generatedBarcode))
        {
            await JS.InvokeVoidAsync("generateBarcode", "barcode-canvas", generatedBarcode);
        }
    }

    private async Task UpdatePrintPreview()
    {
        StateHasChanged();
        if (printSelectedProduct != null && !string.IsNullOrEmpty(printSelectedProduct.CodigoBarras))
        {
             await Task.Delay(50); // Pequeño delay para que el DOM se actualice
             await JS.InvokeVoidAsync("generateBarcode", "print-barcode-canvas", printSelectedProduct.CodigoBarras);
        }
    }

    private async Task GenerateCode()
    {
        var random = new Random();
        bool isUnique = false;
        string newCode = "";
        
        while (!isUnique)
        {
            newCode = DateTime.Now.ToString("yyMMdd") + random.Next(100000, 999999).ToString();
            isUnique = await ProductService.IsBarcodeUniqueAsync(newCode);
        }
        
        generatedBarcode = newCode;
        await JS.InvokeVoidAsync("generateBarcode", "barcode-canvas", generatedBarcode);
        Toast.ShowSuccess("Código generado", "Se ha creado un código único y verificado.");
    }

    private async Task HandleSearch()
    {
        if (searchTerm.Length < 2 && searchTerm.Length > 0) return;
        
        isSearching = true;
        currentPage = 1;
        StateHasChanged();
        
        try 
        {
            var results = await ProductService.SearchProductsAsync(searchTerm);
            searchResults = results.Where(p => string.IsNullOrEmpty(p.CodigoBarras)).ToList();
        }
        finally 
        {
            isSearching = false;
            StateHasChanged();
        }
    }

    private async Task HandlePrintSearch()
    {
        if (printSearchTerm.Length < 3)
        {
            printSearchResults.Clear();
            return;
        }

        printSearchResults = await ProductService.SearchProductsAsync(printSearchTerm);
    }

    private async Task SelectPrintProduct(Producto prod)
    {
        printSelectedProduct = prod;
        printSearchResults.Clear();
        printSearchTerm = prod.Nombre;
        await UpdatePrintPreview();
    }

    private void SetPage(int page)
    {
        if (page >= 1 && page <= TotalPages)
        {
            currentPage = page;
            StateHasChanged();
        }
    }

    private void SelectProduct(Producto prod)
    {
        selectedProduct = prod;
    }

    private async Task AssociateCode()
    {
        if (selectedProduct == null || string.IsNullOrEmpty(generatedBarcode)) return;

        try 
        {
            bool isUnique = await ProductService.IsBarcodeUniqueAsync(generatedBarcode);
            if (!isUnique)
            {
                Toast.ShowError("Código Duplicado", "El código ingresado ya está asignado a otro producto en el sistema.");
                return;
            }

            var prodToUpdate = await ProductService.GetProductByIdAsync(selectedProduct.IdProducto);
            if (prodToUpdate != null)
            {
                prodToUpdate.CodigoBarras = generatedBarcode;
                await ProductService.UpdateProductAsync(prodToUpdate);
                
                Toast.ShowSuccess("Asociación Exitosa", $"{prodToUpdate.Nombre} ahora tiene el código {generatedBarcode}");
                
                // Limpiar estado
                generatedBarcode = "";
                selectedProduct = null;
                searchTerm = "";
                await HandleSearch();
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError("Error de asociación", ex.Message);
        }
    }

    private async Task ExecutePrint()
    {
        if (printSelectedProduct == null) return;
        
        isPrinting = true;
        StateHasChanged();

        try 
        {
            // Imprimir vía QZ: generar 1 sola etiqueta y enviarla N veces como trabajos separados para que corte entre cada una
            byte[] pdfBytes = LabelService.GenerateLabelPdf(printSelectedProduct, selectedTemplate, 1);
            string base64Pdf = Convert.ToBase64String(pdfBytes);
            await JS.InvokeVoidAsync("qzPrintLabelPdf", base64Pdf, AppState.PrinterName, selectedTemplate, printQuantity);
            Toast.ShowSuccess("Impresión Enviada", $"Se han enviado {printQuantity} etiquetas a la impresora.");
        }
        catch (Exception ex)
        {
            Toast.ShowError("Error de Impresión", ex.Message);
        }
        finally
        {
            isPrinting = false;
            StateHasChanged();
        }
    }

    private async Task HandleNewProductSaved(Producto newProd)
    {
        await HandleSearch();
        Toast.ShowInfo("Inventario Actualizado", "El nuevo producto ya está disponible.");
    }
}





