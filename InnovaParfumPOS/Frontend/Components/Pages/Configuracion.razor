    private async Task SaveUser(UserDto dto)
    {
        isSavingUser = true;
        try
        {
            if (dto.IdUsuario.HasValue)
            {
                await UserService.UpdateUserAsync(dto);
                ToastService.ShowSuccess("Usuario actualizado exitosamente.");
            }
            else
            {
                await UserService.CreateUserAsync(dto);
                ToastService.ShowSuccess("Usuario creado exitosamente.");
            }
            
            isUserModalVisible = false;
            userList = await UserService.GetUsersAsync(); // Reload grid
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Error: " + ex.Message);
        }
        finally
        {
            isSavingUser = false;
        }
    }

    private async Task ToggleUserStatus(UserDto user)
    {
        try
        {
            if (user.IdUsuario.HasValue)
            {
                int oldEstado = user.IdEstado;
                await UserService.ToggleUserStatusAsync(user.IdUsuario.Value);
                
                if (oldEstado == 3) user.IdEstado = 1;
                else user.IdEstado = user.IdEstado == 1 ? 2 : 1;
                
                string accion = oldEstado == 3 ? "desbloqueado" : (user.IdEstado == 1 ? "habilitado" : "suspendido");
                ToastService.ShowInfo($"El usuario ha sido {accion}.");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Error al cambiar estado: " + ex.Message);
        }
    }

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            try
            {
                // Limitar tamaño a 2MB para el procesamiento inicial
                if (file.Size > 2 * 1024 * 1024)
                {
                    ToastService.ShowWarning("La imagen es muy pesada. Se intentará comprimir.");
                }

                var format = file.ContentType;
                if (format != "image/png" && format != "image/jpeg" && format != "image/webp")
                {
                    format = "image/png"; // Default to png if unusual
                }
                
                // Redimensionar para optimizar espacio (Max 500x500)
                var resizedFile = await file.RequestImageFileAsync(format, 500, 500);
                
                using var ms = new MemoryStream();
                using var stream = resizedFile.OpenReadStream(1024 * 1024 * 5); // Buffer hasta 5MB
                await stream.CopyToAsync(ms);
                var bytes = ms.ToArray();
                
                settings["Empresa_Logo"] = $"data:{format};base64,{Convert.ToBase64String(bytes)}";
                StateHasChanged();
                ToastService.ShowInfo("Imagen cargada correctamente. No olvide Guardar Cambios.");
            }
            catch (Exception ex)
            {
                ToastService.ShowError("Error al procesar la imagen: " + ex.Message);
            }
        }
    }

    private void ResetLogo()
    {
        settings["Empresa_Logo"] = "images/logo.png";
        StateHasChanged();
    }

    private DateTime fechaPrueba = DateTime.Today;
    private bool isSendingTestReport = false;

    private async Task EnviarReportePrueba()
    {
        if (isSendingTestReport) return;
        isSendingTestReport = true;
        StateHasChanged();
        try
        {
            // Primero, guardar cambios en base de datos para usar las credenciales que estén en pantalla
            await GuardarConfiguracion();

            var date = fechaPrueba;
            byte[] pdfBytes = await DailyReportPdfService.GenerateDailyReportPdfAsync(date);
            bool sent = await EmailService.SendDailyReportEmailAsync(pdfBytes, date);

            if (sent)
            {
                ToastService.ShowSuccess("Reporte de prueba enviado exitosamente por correo.");
            }
            else
            {
                ToastService.ShowError("No se pudo enviar el reporte. Verifique que las credenciales del remitente y destinatario estén configuradas.");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Error al enviar reporte de prueba: " + ex.Message);
        }
        finally
        {
            isSendingTestReport = false;
            StateHasChanged();
        }
    }
