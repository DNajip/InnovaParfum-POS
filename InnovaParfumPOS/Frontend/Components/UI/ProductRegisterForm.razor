@using InnovaParfumPOS.Backend.Models
@using InnovaParfumPOS.Backend.Services
@inject IProductService ProductService
@inject ToastService Toast
@inject UserSession Session

@if (IsVisible)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 9999;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px; overflow: hidden;">
                <div class="modal-header bg-white border-0 p-4 pb-0">
                    <div class="d-flex align-items-center gap-3">
                        <div class="kpi-icon kpi-blue" style="width: 45px; height: 45px; background: rgba(52, 152, 219, 0.1); color: #3498db; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-box-open"></i>
                        </div>
                        <div>
                            <h4 class="modal-title fw-bold mb-0">Registrar Nuevo Producto</h4>
                            <p class="text-muted small mb-0">Complete los datos maestros del producto</p>
                        </div>
                    </div>
                </div>
                <div class="modal-body p-4 pt-3">
                    <div class="row g-3">
                        <!-- Fila 1 -->
                        <div class="col-lg-3">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Código de Barras</label>
                            <div class="input-group-custom bg-light rounded-3 d-flex align-items-center px-2 py-1">
                                <i class="fas fa-barcode text-muted me-2 small"></i>
                                <input type="text" class="form-control bg-transparent border-0 py-1 shadow-none" placeholder="Escanear..." @bind="newProduct.CodigoBarras">
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Nombre del Producto</label>
                            <div class="input-group-custom bg-light rounded-3 d-flex align-items-center px-2 py-1">
                                <i class="fas fa-tag text-muted me-2 small"></i>
                                <input type="text" class="form-control bg-transparent border-0 py-1 shadow-none" placeholder="Nombre completo" @bind="newProduct.Nombre">
                            </div>
                        </div>
                        <div class="col-lg-3">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Categoría</label>
                            <select class="form-select bg-light border-0 py-1 rounded-3 shadow-none" @bind="newProduct.IdCategoria" style="height: 38px;">
                                <option value="" disabled hidden>Seleccione...</option>
                                @foreach (var cat in Categorias)
                                {
                                    <option value="@cat.IdCategoria">@cat.Nombre</option>
                                }
                            </select>
                        </div>

                        <!-- Fila 2 -->
                        @if(SelectedCategory?.PedirMarca == true) { <div class="col-lg-3">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Marca</label>
                            <input type="text" class="form-control bg-light border-0 py-2 rounded-3 shadow-none" placeholder="Marca" @bind="newProduct.Marca">
                        </div> }
                        @if(SelectedCategory?.PedirGenero == true) { <div class="col-lg-3"><label class="form-label mb-1 fw-bold small text-muted text-uppercase">Género</label><input type="text" class="form-control bg-light border-0 py-2 rounded-3 shadow-none" placeholder="Género" @bind="newProduct.Genero"></div> }
                        @if(SelectedCategory?.PedirOrigen == true) { <div class="col-lg-3">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Origen/Tipo</label>
                            <input type="text" class="form-control bg-light border-0 py-2 rounded-3 shadow-none" placeholder="Diseñador, Árabe..." @bind="newProduct.OrigenTipo">
                        </div> }
                        @if(SelectedCategory?.PedirConcentracion == true) { <div class="col-lg-3"><label class="form-label mb-1 fw-bold small text-muted text-uppercase">Concentración</label><input type="text" class="form-control bg-light border-0 py-2 rounded-3 shadow-none" placeholder="EDP, EDT..." @bind="newProduct.Concentracion"></div> }
                        @if(SelectedCategory?.PedirVencimiento == true) { <div class="col-lg-3">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Vencimiento</label>
                            <input type="date" class="form-control bg-light border-0 py-2 rounded-3 shadow-none" @bind="newProduct.FechaVencimiento">
                        </div> }

                        <!-- Fila 3 -->
                        <div class="col-lg-3">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Costo (Compra)</label>
                            <div class="input-group-custom bg-light rounded-3 d-flex align-items-center px-2 py-1">
                                <i class="fas fa-coins text-success me-2 small"></i>
                                <input type="number" class="form-control bg-transparent border-0 py-1 shadow-none" @bind="newProduct.PrecioCompra">
                            </div>
                        </div>
                        <div class="col-lg-3">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">P. Venta</label>
                            <div class="input-group-custom bg-primary bg-opacity-10 rounded-3 d-flex align-items-center px-2 py-1">
                                <i class="fas fa-dollar-sign text-primary me-2 small"></i>
                                <input type="number" class="form-control bg-transparent border-0 py-1 shadow-none fw-bold text-primary" @bind="newProduct.PrecioVenta">
                            </div>
                        </div>
                        <div class="col-lg-3">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Stock Inicial</label>
                            <div class="input-group-custom bg-light rounded-3 d-flex align-items-center px-2 py-1">
                                <i class="fas fa-boxes text-muted me-2 small"></i>
                                <input type="number" class="form-control bg-transparent border-0 py-1 shadow-none" @bind="newProduct.StockActual">
                            </div>
                        </div>
                        <div class="col-lg-3">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Mínimo Alerta</label>
                            <div class="input-group-custom bg-light rounded-3 d-flex align-items-center px-2 py-1">
                                <i class="fas fa-bell text-warning me-2 small"></i>
                                <input type="number" class="form-control bg-transparent border-0 py-1 shadow-none" @bind="newProduct.StockMinimo">
                            </div>
                        </div>

                        <!-- Fila 4 -->
                        <div class="col-lg-12">
                            <div class="mt-2 p-2 px-3 bg-light rounded-4 d-flex align-items-center justify-content-between border border-white">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="form-check form-switch p-0 m-0">
                                        <input class="form-check-input ms-0" type="checkbox" style="width: 2.8rem; height: 1.4rem;" id="flexSwitchCheckChecked" @bind="newProduct.Activo">
                                    </div>
                                    <div>
                                        <label class="form-check-label fw-bold mb-0" for="flexSwitchCheckChecked">Producto Activo en el Sistema</label>
                                        <p class="text-muted small mb-0">Solo los productos activos pueden ser vendidos en el POS</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-2">
                    <button class="btn btn-link text-muted text-decoration-none px-4" @onclick="Close">Cancelar</button>
                    <button class="btn btn-primary rounded-pill px-5 shadow fw-bold py-2" @onclick="HandleCreateProduct" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>Guardando...</span>
                        }
                        else
                        {
                            <i class="fas fa-save me-2"></i><span>Guardar Producto</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public List<Categoria> Categorias { get; set; } = new();
    [Parameter] public EventCallback<Producto> OnProductSaved { get; set; }
    [Parameter] public string? InitialBarcode { get; set; }

    private Producto newProduct = new() { Activo = true, StockActual = 0, StockMinimo = 5 };
    private Categoria? SelectedCategory => Categorias.FirstOrDefault(c => c.IdCategoria == newProduct.IdCategoria);
    private bool isSaving = false;

    protected override void OnParametersSet()
    {
        if (IsVisible)
        {
            if (!string.IsNullOrEmpty(InitialBarcode))
            {
                newProduct.CodigoBarras = InitialBarcode;
            }
            if ((newProduct.IdCategoria == null || newProduct.IdCategoria == 0) && Categorias != null && Categorias.Any())
            {
                var defaultCategory = Categorias.FirstOrDefault(c => c.Nombre != null && c.Nombre.Equals("PERFUMES", StringComparison.OrdinalIgnoreCase));
                if (defaultCategory != null)
                {
                    newProduct.IdCategoria = defaultCategory.IdCategoria;
                }
            }
        }
    }

    private async Task Close()
    {
        newProduct = new Producto { Activo = true, StockActual = 0, StockMinimo = 5 };
        await IsVisibleChanged.InvokeAsync(false);
    }

    private async Task HandleCreateProduct()
    {
        if (string.IsNullOrWhiteSpace(newProduct.Nombre))
        {
            Toast.ShowWarning("El nombre del producto es obligatorio.");
            return;
        }

        if (newProduct.PrecioVenta <= 0)
        {
            Toast.ShowWarning("Debe ingresar un precio de venta al crear un producto.");
            return;
        }

        if (newProduct.IdCategoria == null || newProduct.IdCategoria == 0)
        {
            Toast.ShowWarning("Debe seleccionar una categoría.");
            return;
        }

        try
        {
            isSaving = true;
            newProduct.FechaCreacion = DateTime.Now;
            await ProductService.CreateProductAsync(newProduct);
            Toast.ShowSuccess("Producto registrado", $"{newProduct.Nombre} ha sido creado correctamente.");
            
            var savedProduct = newProduct;
            await OnProductSaved.InvokeAsync(savedProduct);
            await Close();
        }
        catch (Exception ex)
        {
            Toast.ShowError("Error al guardar", ex.Message);
        }
        finally
        {
            isSaving = false;
        }
    }
}




