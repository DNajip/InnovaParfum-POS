@using InnovaParfumPOS.Backend.Models
@using InnovaParfumPOS.Backend.Services
@inject IProductService ProductService
@inject ToastService Toast
@inject UserSession Session
@inject InnovaParfumPOS.Backend.Services.ConfiguracionService ConfigService

@if (IsVisible)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 9999;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px; overflow: hidden;">
                <div class="modal-header bg-white border-0 p-4 pb-0">
                    <div class="d-flex align-items-center gap-3">
                        <div class="kpi-icon kpi-blue" style="width: 45px; height: 45px; background: rgba(52, 152, 219, 0.1); color: #3498db; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-box-open"></i>
                        </div>
                        <div>
                            <h4 class="modal-title fw-bold mb-0">Registrar Nuevo Producto</h4>
                            <p class="text-muted small mb-0">Complete los datos maestros del producto</p>
                        </div>
                    </div>
                </div>
                <div class="modal-body p-4 pt-3">
                    <div class="row g-3">
                        <!-- Fila 1 -->
                        <div class="col-lg-3">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Código de Barras</label>
                            <div class="input-group-custom bg-light rounded-3 d-flex align-items-center px-2 py-1">
                                <i class="fas fa-barcode text-muted me-2 small"></i>
                                <input type="text" class="form-control bg-transparent border-0 py-1 shadow-none" placeholder="Escanear..." @bind="newProduct.CodigoBarras">
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Nombre del Producto</label>
                            <div class="input-group-custom bg-light rounded-3 d-flex align-items-center px-2 py-1">
                                <i class="fas fa-tag text-muted me-2 small"></i>
                                <input type="text" class="form-control bg-transparent border-0 py-1 shadow-none" placeholder="Nombre completo" @bind="newProduct.Nombre">
                            </div>
                        </div>
                        <div class="col-lg-3">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Categoría</label>
                            <select class="form-select bg-light border-0 py-1 rounded-3 shadow-none" @bind="newProduct.IdCategoria" style="height: 38px;">
                                <option value="" disabled hidden>Seleccione...</option>
                                @foreach (var cat in Categorias)
                                {
                                    <option value="@cat.IdCategoria">@cat.Nombre</option>
                                }
                            </select>
                        </div>

                        <!-- Fila 2 -->
                        @if(SelectedCategory?.PedirMarca == true) { <div class="col-lg-3">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Marca</label>
                            <input type="text" class="form-control bg-light border-0 py-2 rounded-3 shadow-none" placeholder="Marca" @bind="newProduct.Marca">
                        </div> }
                        @if(SelectedCategory?.PedirGenero == true) { <div class="col-lg-3"><label class="form-label mb-1 fw-bold small text-muted text-uppercase">Género</label><select class="form-select bg-light border-0 py-2 rounded-3 shadow-none" @bind="newProduct.IdGenero"><option value="">Seleccione...</option>@foreach(var g in Generos){<option value="@g.IdGenero">@g.DescGenero</option>}</select></div> }
                        @if(SelectedCategory?.PedirOrigen == true) { <div class="col-lg-3">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Origen/Tipo</label>
                            <select class="form-select bg-light border-0 py-2 rounded-3 shadow-none" @bind="newProduct.IdOrigen"><option value="">Seleccione...</option>@foreach(var o in Origenes){<option value="@o.IdOrigen">@o.Nombre</option>}</select>
                        </div> }
                        @if(SelectedCategory?.PedirConcentracion == true) { <div class="col-lg-3"><label class="form-label mb-1 fw-bold small text-muted text-uppercase">Concentración</label><select class="form-select bg-light border-0 py-2 rounded-3 shadow-none" @bind="newProduct.IdConcentracion"><option value="">Seleccione...</option>@foreach(var c in Concentraciones){<option value="@c.IdConcentracion">@c.Nombre</option>}</select></div> }
                        @if(SelectedCategory?.PedirVencimiento == true) { <div class="col-lg-3">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Vencimiento</label>
                            <input type="date" class="form-control bg-light border-0 py-2 rounded-3 shadow-none" @bind="newProduct.FechaVencimiento">
                        </div> }
                        @if(SelectedCategory?.PedirMl == true) { <div class="col-lg-3">
                            <label class="form-label mb-1 fw-bold small text-muted text-uppercase">ML</label>
                            <input type="number" step="any" class="form-control bg-light border-0 py-2 rounded-3 shadow-none" placeholder="ML" @bind="newProduct.Ml">
                        </div> }

                        <!-- SECCIÓN COSTOS -->
                        <div class="col-12 mt-4">
                            <div class="p-3 bg-light rounded-4 border" style="border-color: #e2e8f0 !important;">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                                        <i class="fas fa-coins text-success"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-bold text-success">1. COSTOS</h6>
                                        <small class="text-muted">Ingrese los costos para calcular los precios de venta</small>
                                    </div>
                                </div>
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Costo Perfume</label>
                                        <div class="input-group-custom bg-white rounded-3 d-flex align-items-center px-3 py-2 border">
                                            <i class="fas fa-money-bill-wave text-success me-2"></i>
                                            <span class="text-muted me-2 fw-bold">@SimboloMoneda</span>
                                            <input type="number" step="0.01" class="form-control bg-transparent border-0 p-0 shadow-none text-end fw-bold" placeholder="0.00" @bind="newProduct.CostoProducto" @bind:event="oninput" @bind:after="CalculatePrices">
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Costo Envío</label>
                                        <div class="input-group-custom bg-white rounded-3 d-flex align-items-center px-3 py-2 border">
                                            <i class="fas fa-money-bill-wave text-success me-2"></i>
                                            <span class="text-muted me-2 fw-bold">@SimboloMoneda</span>
                                            <input type="number" step="0.01" class="form-control bg-transparent border-0 p-0 shadow-none text-end fw-bold" placeholder="0.00" @bind="newProduct.CostoEnvio" @bind:event="oninput" @bind:after="CalculatePrices">
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Costo Total (Automático)</label>
                                        <div class="input-group-custom bg-success bg-opacity-10 rounded-3 d-flex align-items-center px-3 py-2 border border-success border-opacity-25">
                                            <span class="text-success me-2 fw-bold">@SimboloMoneda</span>
                                            <input type="text" readonly class="form-control bg-transparent border-0 p-0 shadow-none text-end fw-bold text-success" value="@CostoTotal.ToString("N2")">
                                        </div>
                                        <small class="text-muted mt-1 d-block" style="font-size: 0.75rem;">Cálculo: Costo Perfume + Costo Envío</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- SECCIÓN PRECIO MAYORISTA -->
                        <div class="col-12 mt-3">
                            <div class="p-3 bg-white rounded-4 border border-primary border-opacity-25">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                                        <i class="fas fa-users text-primary"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-bold text-primary">2. PRECIO MAYORISTA</h6>
                                        <small class="text-muted">Defina el porcentaje de ganancia y/o el precio para mayoristas</small>
                                    </div>
                                </div>
                                <div class="row g-3 align-items-center">
                                    <div class="col-md-4">
                                        <label class="form-label mb-1 fw-bold small text-muted text-uppercase">% Ganancia Mayorista</label>
                                        <div class="input-group-custom bg-light rounded-3 d-flex align-items-center px-3 py-2 border">
                                            <div class="bg-primary bg-opacity-10 text-primary rounded px-2 py-1 me-2 fw-bold">%</div>
                                            <input type="number" step="0.01" class="form-control bg-transparent border-0 p-0 shadow-none text-end fw-bold" placeholder="0.00" @bind="newProduct.PorcGananciaMayorista" @bind:event="oninput" @bind:after="CalculateMayoristaFromPorc">
                                            <span class="text-muted ms-2">%</span>
                                        </div>
                                        <small class="text-muted mt-1 d-block" style="font-size: 0.75rem;">Basado en el costo total</small>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Precio Mayorista</label>
                                        <div class="input-group-custom bg-light rounded-3 d-flex align-items-center px-3 py-2 border">
                                            <i class="fas fa-money-bill-wave text-primary me-2"></i>
                                            <span class="text-muted me-2 fw-bold">@SimboloMoneda</span>
                                            <input type="number" step="0.01" class="form-control bg-transparent border-0 p-0 shadow-none text-end fw-bold" placeholder="0.00" @bind="newProduct.PrecioMayorista" @bind:event="oninput" @bind:after="CalculatePorcFromMayorista">
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="bg-primary bg-opacity-10 p-3 rounded-3 border border-primary border-opacity-25 h-100 d-flex align-items-center">
                                            <i class="fas fa-info-circle text-primary me-3 fs-4"></i>
                                            <small class="text-primary fw-medium mb-0" style="line-height: 1.2;">Puede ingresar el porcentaje o el precio, el otro se calculará automáticamente.</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- SECCIÓN PRECIO MINORISTA -->
                        <div class="col-12 mt-3">
                            <div class="p-3 bg-white rounded-4 border" style="border-color: #d8b4fe !important;">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px; background-color: #f3e8ff;">
                                        <i class="fas fa-user" style="color: #9333ea;"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-bold" style="color: #9333ea;">3. PRECIO MINORISTA</h6>
                                        <small class="text-muted">Defina el porcentaje de ganancia y/o el precio para minoristas</small>
                                    </div>
                                </div>
                                <div class="row g-3 align-items-center">
                                    <div class="col-md-4">
                                        <label class="form-label mb-1 fw-bold small text-muted text-uppercase">% Ganancia Minorista</label>
                                        <div class="input-group-custom bg-light rounded-3 d-flex align-items-center px-3 py-2 border">
                                            <div class="rounded px-2 py-1 me-2 fw-bold" style="background-color: #f3e8ff; color: #9333ea;">%</div>
                                            <input type="number" step="0.01" class="form-control bg-transparent border-0 p-0 shadow-none text-end fw-bold" placeholder="0.00" @bind="newProduct.PorcGananciaMinorista" @bind:event="oninput" @bind:after="CalculateMinoristaFromPorc">
                                            <span class="text-muted ms-2">%</span>
                                        </div>
                                        <small class="text-muted mt-1 d-block" style="font-size: 0.75rem;">Basado en el costo total</small>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Precio Minorista</label>
                                        <div class="input-group-custom bg-light rounded-3 d-flex align-items-center px-3 py-2 border">
                                            <i class="fas fa-money-bill-wave me-2" style="color: #9333ea;"></i>
                                            <span class="text-muted me-2 fw-bold">@SimboloMoneda</span>
                                            <input type="number" step="0.01" class="form-control bg-transparent border-0 p-0 shadow-none text-end fw-bold" placeholder="0.00" @bind="newProduct.PrecioMinorista" @bind:event="oninput" @bind:after="CalculatePorcFromMinorista">
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="p-3 rounded-3 border h-100 d-flex align-items-center" style="background-color: #faf5ff; border-color: #e9d5ff !important;">
                                            <i class="fas fa-info-circle me-3 fs-4" style="color: #9333ea;"></i>
                                            <small class="fw-medium mb-0" style="color: #7e22ce; line-height: 1.2;">Puede ingresar el porcentaje o el precio, el otro se calculará automáticamente.</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- SECCIÓN STOCK Y ESTADO -->
                        <div class="col-12 mt-3">
                            <div class="p-3 bg-white rounded-4 border border-warning border-opacity-25" style="background-color: #fffbeb !important;">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="rounded-circle bg-warning bg-opacity-25 d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                                        <i class="fas fa-box-open text-warning"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-bold text-warning">4. STOCK Y ESTADO</h6>
                                        <small class="text-muted">Configure el stock inicial, mínimo y el estado del producto</small>
                                    </div>
                                </div>
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Stock Inicial</label>
                                        <div class="input-group-custom bg-white rounded-3 d-flex align-items-center px-3 py-2 border">
                                            <i class="fas fa-boxes text-warning me-2"></i>
                                            <input type="number" class="form-control bg-transparent border-0 p-0 shadow-none" placeholder="0" @bind="newProduct.StockActual" onfocus="this.select()">
                                        </div>
                                        <small class="text-muted mt-1 d-block" style="font-size: 0.75rem;">Cantidad inicial en inventario</small>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Stock Mínimo (Alerta)</label>
                                        <div class="input-group-custom bg-white rounded-3 d-flex align-items-center px-3 py-2 border">
                                            <i class="fas fa-bell text-warning me-2"></i>
                                            <input type="number" class="form-control bg-transparent border-0 p-0 shadow-none" placeholder="5" @bind="newProduct.StockMinimo" onfocus="this.select()">
                                        </div>
                                        <small class="text-muted mt-1 d-block" style="font-size: 0.75rem;">Se genera alerta al llegar a este nivel</small>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label mb-1 fw-bold small text-muted text-uppercase">Producto Activo</label>
                                        <div class="bg-white rounded-3 d-flex align-items-center px-3 py-2 border h-auto" style="height: 40px !important;">
                                            <div class="form-check form-switch p-0 m-0 d-flex align-items-center w-100">
                                                <input class="form-check-input ms-0 me-3" type="checkbox" style="width: 2.5rem; height: 1.25rem;" id="chkActivo" @bind="newProduct.Activo">
                                                <label class="form-check-label fw-bold m-0" for="chkActivo">Sí, activar producto</label>
                                            </div>
                                        </div>
                                        <small class="text-muted mt-1 d-block" style="font-size: 0.75rem;">Solo los productos activos pueden ser vendidos en el POS</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-2">
                    <button class="btn btn-link text-muted text-decoration-none px-4" @onclick="Close">Cancelar</button>
                    <button class="btn btn-dark rounded-pill px-5 shadow fw-bold py-2" @onclick="HandleCreateProduct" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>Guardando...</span>
                        }
                        else
                        {
                            <i class="fas fa-save me-2"></i><span>Guardar Producto</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public List<Categoria> Categorias { get; set; } = new();
    [Parameter] public List<Genero> Generos { get; set; } = new();
    [Parameter] public List<Origen> Origenes { get; set; } = new();
    [Parameter] public List<Concentracion> Concentraciones { get; set; } = new();
    [Parameter] public EventCallback<Producto> OnProductSaved { get; set; }
    [Parameter] public string? InitialBarcode { get; set; }

    private Producto newProduct = new() { Activo = true, StockActual = 0, StockMinimo = 5 };
    private Categoria? SelectedCategory => Categorias.FirstOrDefault(c => c.IdCategoria == newProduct.IdCategoria);
    private bool isSaving = false;
    private string SimboloMoneda = "C$";

    private decimal CostoTotal => (newProduct.CostoProducto ?? 0) + (newProduct.CostoEnvio ?? 0);

    protected override async Task OnInitializedAsync()
    {
        var moneda = await ConfigService.GetSettingAsync("Moneda_Principal");
        SimboloMoneda = moneda == "USD" ? "$" : "C$";
    }

    protected override void OnParametersSet()
    {
        if (IsVisible)
        {
            if (!string.IsNullOrEmpty(InitialBarcode))
            {
                newProduct.CodigoBarras = InitialBarcode;
            }
            if ((newProduct.IdCategoria == null || newProduct.IdCategoria == 0) && Categorias != null && Categorias.Any())
            {
                var defaultCategory = Categorias.FirstOrDefault(c => c.Nombre != null && c.Nombre.Equals("PERFUMES", StringComparison.OrdinalIgnoreCase));
                if (defaultCategory != null)
                {
                    newProduct.IdCategoria = defaultCategory.IdCategoria;
                }
            }
        }
    }

    private void CalculatePrices()
    {
        CalculateMayoristaFromPorc();
        CalculateMinoristaFromPorc();
    }

    private void CalculateMayoristaFromPorc()
    {
        if (newProduct.PorcGananciaMayorista.HasValue && CostoTotal > 0)
        {
            newProduct.PrecioMayorista = Math.Round(CostoTotal + (CostoTotal * (newProduct.PorcGananciaMayorista.Value / 100m)), 2);
        }
    }

    private void CalculatePorcFromMayorista()
    {
        if (newProduct.PrecioMayorista.HasValue && CostoTotal > 0)
        {
            newProduct.PorcGananciaMayorista = Math.Round(((newProduct.PrecioMayorista.Value - CostoTotal) / CostoTotal) * 100m, 2);
        }
    }

    private void CalculateMinoristaFromPorc()
    {
        if (newProduct.PorcGananciaMinorista.HasValue && CostoTotal > 0)
        {
            newProduct.PrecioMinorista = Math.Round(CostoTotal + (CostoTotal * (newProduct.PorcGananciaMinorista.Value / 100m)), 2);
        }
    }

    private void CalculatePorcFromMinorista()
    {
        if (newProduct.PrecioMinorista.HasValue && CostoTotal > 0)
        {
            newProduct.PorcGananciaMinorista = Math.Round(((newProduct.PrecioMinorista.Value - CostoTotal) / CostoTotal) * 100m, 2);
        }
    }

    private async Task Close()
    {
        newProduct = new Producto { Activo = true, StockActual = 0, StockMinimo = 5 };
        await IsVisibleChanged.InvokeAsync(false);
    }

    private async Task HandleCreateProduct()
    {
        if (string.IsNullOrWhiteSpace(newProduct.Nombre))
        {
            Toast.ShowWarning("El nombre del producto es obligatorio.");
            return;
        }

        if ((newProduct.PrecioMinorista ?? 0) <= 0)
        {
            Toast.ShowWarning("Debe ingresar un precio minorista al crear un producto.");
            return;
        }

        if (newProduct.IdCategoria == null || newProduct.IdCategoria == 0)
        {
            Toast.ShowWarning("Debe seleccionar una categoría.");
            return;
        }

        var selectedCat = Categorias.FirstOrDefault(c => c.IdCategoria == newProduct.IdCategoria);
        if (selectedCat != null)
        {
            if (selectedCat.Nombre != null && selectedCat.Nombre.Contains("PERFUME", StringComparison.OrdinalIgnoreCase))
                newProduct.TipoProducto = "PERFUME";
            else
                newProduct.TipoProducto = "ARTICULO_VARIO";
        }

        try
        {
            isSaving = true;
            newProduct.FechaCreacion = DateTime.Now;
            await ProductService.CreateProductAsync(newProduct);
            Toast.ShowSuccess("Producto registrado", $"{newProduct.Nombre} ha sido creado correctamente.");
            
            var savedProduct = newProduct;
            await OnProductSaved.InvokeAsync(savedProduct);
            await Close();
        }
        catch (Exception ex)
        {
            Toast.ShowError("Error al guardar", ex.Message);
        }
        finally
        {
            isSaving = false;
        }
    }
}
