@using InnovaParfumPOS.Backend.Models
@using InnovaParfumPOS.Backend.Services
@inject IProductService ProductService
@inject ToastService Toast
@inject UserSession Session
@inject InnovaParfumPOS.Backend.Services.ConfiguracionService ConfigService

@if (IsVisible)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 9999;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 16px; overflow: hidden;">
                <div class="modal-header bg-white border-0 p-3 pb-0">
                    <div class="d-flex align-items-center gap-2">
                        <div class="kpi-icon kpi-blue" style="width: 35px; height: 35px; background: rgba(52, 152, 219, 0.1); color: #3498db; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem;">
                            <i class="fas fa-box-open"></i>
                        </div>
                        <div>
                            <h5 class="modal-title fw-bold mb-0">Registrar Nuevo Producto</h5>
                            <p class="text-muted mb-0" style="font-size: 0.75rem;">Complete los datos maestros del producto</p>
                        </div>
                    </div>
                </div>
                <div class="modal-body p-3 pt-2" style="max-height: 80vh; overflow-y: auto;">
                    <div class="row g-2">
                        <!-- Fila 1 -->
                        <div class="col-lg-3">
                            <label class="form-label mb-0 fw-bold text-muted text-uppercase" style="font-size: 0.65rem;">Código de Barras</label>
                            <div class="input-group-custom bg-light rounded-2 d-flex align-items-center px-2 py-1">
                                <i class="fas fa-barcode text-muted me-2" style="font-size: 0.8rem;"></i>
                                <input type="text" class="form-control bg-transparent border-0 p-0 shadow-none" style="font-size: 0.85rem;" placeholder="Escanear..." @bind="newProduct.CodigoBarras">
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <label class="form-label mb-0 fw-bold text-muted text-uppercase" style="font-size: 0.65rem;">Nombre del Producto</label>
                            <div class="input-group-custom bg-light rounded-2 d-flex align-items-center px-2 py-1">
                                <i class="fas fa-tag text-muted me-2" style="font-size: 0.8rem;"></i>
                                <input type="text" class="form-control bg-transparent border-0 p-0 shadow-none" style="font-size: 0.85rem;" placeholder="Nombre completo" @bind="newProduct.Nombre">
                            </div>
                        </div>
                        <div class="col-lg-3">
                            <label class="form-label mb-0 fw-bold text-muted text-uppercase" style="font-size: 0.65rem;">Categoría</label>
                            <select class="form-select bg-light border-0 rounded-2 shadow-none px-2 py-1" @bind="newProduct.IdCategoria" style="font-size: 0.85rem; height: 28px;">
                                <option value="" disabled hidden>Seleccione...</option>
                                @foreach (var cat in Categorias)
                                {
                                    <option value="@cat.IdCategoria">@cat.Nombre</option>
                                }
                            </select>
                        </div>

                        <!-- Fila 2 -->
                        @if(SelectedCategory?.PedirMarca == true) { <div class="col-lg-2">
                            <label class="form-label mb-0 fw-bold text-muted text-uppercase" style="font-size: 0.65rem;">Marca</label>
                            <input type="text" class="form-control bg-light border-0 py-1 px-2 rounded-2 shadow-none" style="font-size: 0.85rem;" placeholder="Marca" @bind="newProduct.Marca">
                        </div> }
                        @if(SelectedCategory?.PedirGenero == true) { <div class="col-lg-2"><label class="form-label mb-0 fw-bold text-muted text-uppercase" style="font-size: 0.65rem;">Género</label><select class="form-select bg-light border-0 py-1 px-2 rounded-2 shadow-none" style="font-size: 0.85rem;" @bind="newProduct.IdGenero"><option value="">Sel...</option>@foreach(var g in Generos){<option value="@g.IdGenero">@g.DescGenero</option>}</select></div> }
                        @if(SelectedCategory?.PedirOrigen == true) { <div class="col-lg-2">
                            <label class="form-label mb-0 fw-bold text-muted text-uppercase" style="font-size: 0.65rem;">Origen</label>
                            <select class="form-select bg-light border-0 py-1 px-2 rounded-2 shadow-none" style="font-size: 0.85rem;" @bind="newProduct.IdOrigen"><option value="">Sel...</option>@foreach(var o in Origenes){<option value="@o.IdOrigen">@o.Nombre</option>}</select>
                        </div> }
                        @if(SelectedCategory?.PedirConcentracion == true) { <div class="col-lg-2"><label class="form-label mb-0 fw-bold text-muted text-uppercase" style="font-size: 0.65rem;">Concentración</label><select class="form-select bg-light border-0 py-1 px-2 rounded-2 shadow-none" style="font-size: 0.85rem;" @bind="newProduct.IdConcentracion"><option value="">Sel...</option>@foreach(var c in Concentraciones){<option value="@c.IdConcentracion">@c.Nombre</option>}</select></div> }
                        @if(SelectedCategory?.PedirVencimiento == true) { <div class="col-lg-2">
                            <label class="form-label mb-0 fw-bold text-muted text-uppercase" style="font-size: 0.65rem;">Vencimiento</label>
                            <input type="date" class="form-control bg-light border-0 py-1 px-2 rounded-2 shadow-none" style="font-size: 0.85rem;" @bind="newProduct.FechaVencimiento">
                        </div> }
                        @if(SelectedCategory?.PedirMl == true) { <div class="col-lg-2">
                            <label class="form-label mb-0 fw-bold text-muted text-uppercase" style="font-size: 0.65rem;">ML</label>
                            <input type="number" step="any" class="form-control bg-light border-0 py-1 px-2 rounded-2 shadow-none" style="font-size: 0.85rem;" placeholder="ML" @bind="newProduct.Ml">
                        </div> }

                        <div class="col-12 mt-1"></div>

                        <!-- SECCIÓN COSTOS Y STOCK (LADO A LADO) -->
                        <div class="col-lg-6">
                            <div class="p-2 bg-light rounded-3 border h-100" style="border-color: #e2e8f0 !important;">
                                <div class="d-flex align-items-center mb-2">
                                    <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center me-2" style="width: 24px; height: 24px;">
                                        <i class="fas fa-coins text-success" style="font-size: 0.75rem;"></i>
                                    </div>
                                    <h6 class="mb-0 fw-bold text-success" style="font-size: 0.85rem;">1. COSTOS</h6>
                                </div>
                                <div class="row g-2">
                                    <div class="col-4">
                                        <label class="form-label mb-0 fw-bold text-muted text-uppercase" style="font-size: 0.6rem;">Perfume</label>
                                        <div class="input-group-custom bg-white rounded-2 d-flex align-items-center px-2 py-1 border">
                                            <span class="text-muted me-1 fw-bold" style="font-size: 0.75rem;">@SimboloMoneda</span>
                                            <input type="number" step="0.01" class="form-control bg-transparent border-0 p-0 shadow-none text-end fw-bold" style="font-size: 0.8rem;" placeholder="0.00" @bind="newProduct.CostoProducto" @bind:event="oninput" @bind:after="CalculatePrices">
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <label class="form-label mb-0 fw-bold text-muted text-uppercase" style="font-size: 0.6rem;">Envío</label>
                                        <div class="input-group-custom bg-white rounded-2 d-flex align-items-center px-2 py-1 border">
                                            <span class="text-muted me-1 fw-bold" style="font-size: 0.75rem;">@SimboloMoneda</span>
                                            <input type="number" step="0.01" class="form-control bg-transparent border-0 p-0 shadow-none text-end fw-bold" style="font-size: 0.8rem;" placeholder="0.00" @bind="newProduct.CostoEnvio" @bind:event="oninput" @bind:after="CalculatePrices">
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <label class="form-label mb-0 fw-bold text-muted text-uppercase" style="font-size: 0.6rem;">Total</label>
                                        <div class="input-group-custom bg-success bg-opacity-10 rounded-2 d-flex align-items-center px-2 py-1 border border-success border-opacity-25">
                                            <span class="text-success me-1 fw-bold" style="font-size: 0.75rem;">@SimboloMoneda</span>
                                            <input type="text" readonly class="form-control bg-transparent border-0 p-0 shadow-none text-end fw-bold text-success" style="font-size: 0.8rem;" value="@CostoTotal.ToString("N2")">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-6">
                            <div class="p-2 bg-white rounded-3 border border-warning border-opacity-50 h-100" style="background-color: #fffbeb !important;">
                                <div class="d-flex align-items-center mb-2">
                                    <div class="rounded-circle bg-warning bg-opacity-25 d-flex align-items-center justify-content-center me-2" style="width: 24px; height: 24px;">
                                        <i class="fas fa-box-open text-warning" style="font-size: 0.75rem;"></i>
                                    </div>
                                    <h6 class="mb-0 fw-bold text-warning" style="font-size: 0.85rem;">4. STOCK Y ESTADO</h6>
                                </div>
                                <div class="row g-2">
                                    <div class="col-4">
                                        <label class="form-label mb-0 fw-bold text-muted text-uppercase" style="font-size: 0.6rem;">Inicial</label>
                                        <div class="input-group-custom bg-white rounded-2 d-flex align-items-center px-2 py-1 border">
                                            <input type="number" class="form-control bg-transparent border-0 p-0 shadow-none text-center" style="font-size: 0.8rem;" placeholder="0" @bind="newProduct.StockActual" onfocus="this.select()">
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <label class="form-label mb-0 fw-bold text-muted text-uppercase" style="font-size: 0.6rem;">Alerta</label>
                                        <div class="input-group-custom bg-white rounded-2 d-flex align-items-center px-2 py-1 border">
                                            <input type="number" class="form-control bg-transparent border-0 p-0 shadow-none text-center" style="font-size: 0.8rem;" placeholder="5" @bind="newProduct.StockMinimo" onfocus="this.select()">
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <label class="form-label mb-0 fw-bold text-muted text-uppercase" style="font-size: 0.6rem;">Activo</label>
                                        <div class="bg-white rounded-2 d-flex align-items-center justify-content-center border h-auto" style="padding: 3px 0;">
                                            <div class="form-check form-switch p-0 m-0 d-flex align-items-center justify-content-center">
                                                <input class="form-check-input ms-0 m-0" type="checkbox" style="width: 2rem; height: 1rem; cursor: pointer;" id="chkActivo" @bind="newProduct.Activo">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- SECCIÓN PRECIOS (LADO A LADO) -->
                        <div class="col-lg-6 mt-2">
                            <div class="p-2 bg-white rounded-3 border border-primary border-opacity-25 h-100">
                                <div class="d-flex align-items-center mb-2 justify-content-between">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center me-2" style="width: 24px; height: 24px;">
                                            <i class="fas fa-users text-primary" style="font-size: 0.75rem;"></i>
                                        </div>
                                        <h6 class="mb-0 fw-bold text-primary" style="font-size: 0.85rem;">2. PRECIO MAYORISTA</h6>
                                    </div>
                                    <i class="fas fa-info-circle text-primary opacity-50" title="Ingrese % o Precio. Se auto-calculan mutuamente."></i>
                                </div>
                                <div class="row g-2 align-items-center">
                                    <div class="col-6">
                                        <label class="form-label mb-0 fw-bold text-muted text-uppercase" style="font-size: 0.6rem;">% Ganancia</label>
                                        <div class="input-group-custom bg-light rounded-2 d-flex align-items-center px-2 py-1 border">
                                            <div class="text-primary me-1 fw-bold" style="font-size: 0.75rem;">%</div>
                                            <input type="number" step="0.01" class="form-control bg-transparent border-0 p-0 shadow-none text-end fw-bold" style="font-size: 0.8rem;" placeholder="0.00" @bind="newProduct.PorcGananciaMayorista" @bind:event="oninput" @bind:after="CalculateMayoristaFromPorc">
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label mb-0 fw-bold text-muted text-uppercase" style="font-size: 0.6rem;">Precio Sugerido</label>
                                        <div class="input-group-custom bg-light rounded-2 d-flex align-items-center px-2 py-1 border">
                                            <span class="text-muted me-1 fw-bold" style="font-size: 0.75rem;">@SimboloMoneda</span>
                                            <input type="number" step="0.01" class="form-control bg-transparent border-0 p-0 shadow-none text-end fw-bold text-primary" style="font-size: 0.8rem;" placeholder="0.00" @bind="newProduct.PrecioMayorista" @bind:event="oninput" @bind:after="CalculatePorcFromMayorista">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-6 mt-2">
                            <div class="p-2 bg-white rounded-3 border h-100" style="border-color: #d8b4fe !important;">
                                <div class="d-flex align-items-center mb-2 justify-content-between">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 24px; height: 24px; background-color: #f3e8ff;">
                                            <i class="fas fa-user" style="color: #9333ea; font-size: 0.75rem;"></i>
                                        </div>
                                        <h6 class="mb-0 fw-bold" style="color: #9333ea; font-size: 0.85rem;">3. PRECIO MINORISTA</h6>
                                    </div>
                                    <i class="fas fa-info-circle opacity-50" style="color: #9333ea;" title="Ingrese % o Precio. Se auto-calculan mutuamente."></i>
                                </div>
                                <div class="row g-2 align-items-center">
                                    <div class="col-6">
                                        <label class="form-label mb-0 fw-bold text-muted text-uppercase" style="font-size: 0.6rem;">% Ganancia</label>
                                        <div class="input-group-custom bg-light rounded-2 d-flex align-items-center px-2 py-1 border">
                                            <div class="me-1 fw-bold" style="color: #9333ea; font-size: 0.75rem;">%</div>
                                            <input type="number" step="0.01" class="form-control bg-transparent border-0 p-0 shadow-none text-end fw-bold" style="font-size: 0.8rem;" placeholder="0.00" @bind="newProduct.PorcGananciaMinorista" @bind:event="oninput" @bind:after="CalculateMinoristaFromPorc">
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label mb-0 fw-bold text-muted text-uppercase" style="font-size: 0.6rem;">Precio Público</label>
                                        <div class="input-group-custom bg-light rounded-2 d-flex align-items-center px-2 py-1 border">
                                            <span class="text-muted me-1 fw-bold" style="font-size: 0.75rem;">@SimboloMoneda</span>
                                            <input type="number" step="0.01" class="form-control bg-transparent border-0 p-0 shadow-none text-end fw-bold" style="color: #9333ea; font-size: 0.8rem;" placeholder="0.00" @bind="newProduct.PrecioMinorista" @bind:event="oninput" @bind:after="CalculatePorcFromMinorista">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="modal-footer border-0 p-3 pt-2">
                    <button class="btn btn-link text-muted text-decoration-none px-3" style="font-size: 0.85rem;" @onclick="Close">Cancelar</button>
                    <button class="btn btn-dark rounded-pill px-4 shadow fw-bold py-1" style="font-size: 0.85rem;" @onclick="HandleCreateProduct" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>Guardando...</span>
                        }
                        else
                        {
                            <i class="fas fa-save me-2"></i><span>Guardar Producto</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public List<Categoria> Categorias { get; set; } = new();
    [Parameter] public List<Genero> Generos { get; set; } = new();
    [Parameter] public List<Origen> Origenes { get; set; } = new();
    [Parameter] public List<Concentracion> Concentraciones { get; set; } = new();
    [Parameter] public EventCallback<Producto> OnProductSaved { get; set; }
    [Parameter] public string? InitialBarcode { get; set; }

    private Producto newProduct = new() { Activo = true, StockActual = 0, StockMinimo = 5 };
    private Categoria? SelectedCategory => Categorias.FirstOrDefault(c => c.IdCategoria == newProduct.IdCategoria);
    private bool isSaving = false;
    private string SimboloMoneda = "C$";

    private decimal CostoTotal => (newProduct.CostoProducto ?? 0) + (newProduct.CostoEnvio ?? 0);

    protected override async Task OnInitializedAsync()
    {
        var moneda = await ConfigService.GetSettingAsync("Moneda_Principal");
        SimboloMoneda = moneda == "USD" ? "$" : "C$";
    }

    protected override void OnParametersSet()
    {
        if (IsVisible)
        {
            if (!string.IsNullOrEmpty(InitialBarcode))
            {
                newProduct.CodigoBarras = InitialBarcode;
            }
            if ((newProduct.IdCategoria == null || newProduct.IdCategoria == 0) && Categorias != null && Categorias.Any())
            {
                var defaultCategory = Categorias.FirstOrDefault(c => c.Nombre != null && c.Nombre.Equals("PERFUMES", StringComparison.OrdinalIgnoreCase));
                if (defaultCategory != null)
                {
                    newProduct.IdCategoria = defaultCategory.IdCategoria;
                }
            }
        }
    }

    private void CalculatePrices()
    {
        CalculateMayoristaFromPorc();
        CalculateMinoristaFromPorc();
    }

    private void CalculateMayoristaFromPorc()
    {
        if (newProduct.PorcGananciaMayorista.HasValue && CostoTotal > 0)
        {
            newProduct.PrecioMayorista = Math.Round(CostoTotal + (CostoTotal * (newProduct.PorcGananciaMayorista.Value / 100m)), 2);
        }
    }

    private void CalculatePorcFromMayorista()
    {
        if (newProduct.PrecioMayorista.HasValue && CostoTotal > 0)
        {
            newProduct.PorcGananciaMayorista = Math.Round(((newProduct.PrecioMayorista.Value - CostoTotal) / CostoTotal) * 100m, 2);
        }
    }

    private void CalculateMinoristaFromPorc()
    {
        if (newProduct.PorcGananciaMinorista.HasValue && CostoTotal > 0)
        {
            newProduct.PrecioMinorista = Math.Round(CostoTotal + (CostoTotal * (newProduct.PorcGananciaMinorista.Value / 100m)), 2);
        }
    }

    private void CalculatePorcFromMinorista()
    {
        if (newProduct.PrecioMinorista.HasValue && CostoTotal > 0)
        {
            newProduct.PorcGananciaMinorista = Math.Round(((newProduct.PrecioMinorista.Value - CostoTotal) / CostoTotal) * 100m, 2);
        }
    }

    private async Task Close()
    {
        newProduct = new Producto { Activo = true, StockActual = 0, StockMinimo = 5 };
        await IsVisibleChanged.InvokeAsync(false);
    }

    private async Task HandleCreateProduct()
    {
        if (string.IsNullOrWhiteSpace(newProduct.Nombre))
        {
            Toast.ShowWarning("El nombre del producto es obligatorio.");
            return;
        }

        if ((newProduct.PrecioMinorista ?? 0) <= 0)
        {
            Toast.ShowWarning("Debe ingresar un precio minorista al crear un producto.");
            return;
        }

        if (newProduct.IdCategoria == null || newProduct.IdCategoria == 0)
        {
            Toast.ShowWarning("Debe seleccionar una categoría.");
            return;
        }

        var selectedCat = Categorias.FirstOrDefault(c => c.IdCategoria == newProduct.IdCategoria);
        if (selectedCat != null)
        {
            if (selectedCat.Nombre != null && selectedCat.Nombre.Contains("PERFUME", StringComparison.OrdinalIgnoreCase))
                newProduct.TipoProducto = "PERFUME";
            else
                newProduct.TipoProducto = "ARTICULO_VARIO";
        }

        try
        {
            isSaving = true;
            newProduct.FechaCreacion = DateTime.Now;
            await ProductService.CreateProductAsync(newProduct);
            Toast.ShowSuccess("Producto registrado", $"{newProduct.Nombre} ha sido creado correctamente.");
            
            var savedProduct = newProduct;
            await OnProductSaved.InvokeAsync(savedProduct);
            await Close();
        }
        catch (Exception ex)
        {
            Toast.ShowError("Error al guardar", ex.Message);
        }
        finally
        {
            isSaving = false;
        }
    }
}
