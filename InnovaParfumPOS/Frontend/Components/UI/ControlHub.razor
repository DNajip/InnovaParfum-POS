@using InnovaParfumPOS.Backend.Services
@using InnovaParfumPOS.Backend.Models
@using Microsoft.JSInterop
@implements IDisposable
@inject NavigationManager Navigation
@inject IShiftService ShiftService
@inject UserSession UserSession
@inject ToastService ToastService
@inject ConfiguracionService ConfigService
<footer class="pos-footer">
    <div class="position-relative w-100">
        @if (showSelectionModal)
        {
            <div class="cash-options-menu animate__animated animate__fadeInUp">
                <button type="button" class="option-item" @onclick="OpenCashEntry">
                    <i class="fas fa-plus-circle text-primary"></i>
                    <div class="text-start">
                        <div class="fw-bold">Ingresar Cambio</div>
                        <div class="x-small text-muted">Añadir sencillo</div>
                    </div>
                </button>
                <div class="dropdown-divider m-0"></div>
                <button type="button" class="option-item text-secondary" @onclick="ReprintLastZReport">
                    <i class="fas fa-print"></i>
                    <div class="text-start">
                        <div class="fw-bold">Reimprimir Arqueo</div>
                        <div class="x-small text-muted">Último reporte Z</div>
                    </div>
                </button>
                <div class="dropdown-divider m-0"></div>
                <button type="button" class="option-item text-danger" @onclick="OpenCloseShift">
                    <i class="fas fa-lock"></i>
                    <div class="text-start">
                        <div class="fw-bold">Cerrar Turno</div>
                        <div class="x-small text-muted">Finalizar jornada</div>
                    </div>
                </button>
            </div>
            <div class="menu-overlay" @onclick="() => showSelectionModal = false"></div>
        }

        <button type="button" class="action-btn w-100 h-100 @(UserSession.ActiveShift != null ? "action-btn-success" : "btn-warning text-dark")" @onclick="ToggleShift">
            <i class="fas fa-cash-register"></i>
            <span>@(UserSession.ActiveShift != null ? "Caja abierta" : "Caja cerrada")</span>
            <span class="sub-text">@(UserSession.ActiveShift != null ? "Gestionar turno" : "Abrir turno")</span>
        </button>
    </div>

    <a href="/inventario" class="action-btn @(IsActive("/inventario") ? "active" : "")">
        <i class="fas fa-boxes"></i>
        <span>Precio / Inventario</span>
    </a>
    <a href="/clientes" class="action-btn @(IsActive("/clientes") ? "active" : "")">
        <i class="fas fa-users"></i>
        <span>Clientes</span>
    </a>
    <a href="/facturas" class="action-btn @(IsActive("/facturas") ? "active" : "")">
        <i class="fas fa-file-invoice"></i>
        <span>Facturas</span>
    </a>
</footer>

<style>
    .cash-options-menu {
        position: absolute;
        bottom: 110%;
        left: 50%;
        transform: translateX(-50%);
        background: white;
        min-width: 200px;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        z-index: 2060;
        overflow: hidden;
        border: 1px solid rgba(0,0,0,0.05);
    }

    .option-item {
        width: 100%;
        padding: 12px 16px;
        border: none;
        background: none;
        display: flex;
        align-items: center;
        gap: 12px;
        transition: background 0.2s;
    }

    .option-item:hover {
        background: #f8f9fa;
    }

    .option-item i {
        font-size: 1.2rem;
        width: 24px;
        text-align: center;
    }

    .x-small {
        font-size: 0.7rem;
        display: block;
    }

    .menu-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 2050;
    }
</style>

<!-- Modales de Caja -->
@if (showOpenModal)
{
    <CashCountModal OnClose="() => showOpenModal = false" OnSuccess="HandleOpenSuccess" />
}

@if (showCloseModal)
{
    <CashCloseModal OnClose="() => showCloseModal = false" OnSuccess="HandleCloseSuccess" />
}

@if (showEntryModal)
{
    <CashEntryModal OnClose="() => showEntryModal = false" OnSuccess="() => showEntryModal = false" />
}

@code {
    private bool showOpenModal = false;
    private bool showCloseModal = false;
    private bool showSelectionModal = false;
    private bool showEntryModal = false;

    protected override async Task OnInitializedAsync()
    {
        UserSession.OnChange += StateHasChanged;
        Navigation.LocationChanged += HandleLocationChanged;

        if (UserSession.UserId.HasValue && UserSession.ActiveShift == null)
        {
            UserSession.ActiveShift = await ShiftService.GetActiveShiftAsync(UserSession.UserId.Value);
        }
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    private void ToggleShift()
    {
        if (UserSession.ActiveShift != null)
        {
            showSelectionModal = true;
        }
        else
        {
            showOpenModal = true;
        }
    }

    private void OpenCashEntry()
    {
        showSelectionModal = false;
        showEntryModal = true;
    }

    private void OpenCloseShift()
    {
        showSelectionModal = false;
        showCloseModal = true;
    }

    private void HandleCloseSuccess()
    {
        showCloseModal = false;
        StateHasChanged();
    }

    private void HandleOpenSuccess(Turno turno)
    {
        UserSession.ActiveShift = turno;
        showOpenModal = false;
        StateHasChanged();
    }

    private async Task ReprintLastZReport()
    {
        try
        {
            if (!UserSession.UserId.HasValue) return;
            
            var lastShift = await ShiftService.GetLastClosedShiftAsync(UserSession.UserId.Value);
            if (lastShift == null)
            {
                ToastService.ShowError("No se encontraron turnos cerrados.");
                return;
            }

            var settings = await ConfigService.GetAllSettingsAsync();
            var configPrint = new {
                nombreNegocio = settings.GetValueOrDefault("Empresa_Nombre", "INNOVATEC POS"),
                printerName = settings.GetValueOrDefault("Hardware_Impresora_Nombre", "")
            };

            var printData = new {
                idTurno = lastShift.IdTurno,
                cajero = UserSession.Username,
                fechaApertura = lastShift.FechaApertura,
                fechaCierre = lastShift.FechaCierre ?? DateTime.Now,
                totalVentasNio = lastShift.TotalVentasNio,
                totalEfectivoNio = lastShift.TotalEfectivoNio,
                totalEfectivoUsd = lastShift.TotalEfectivoUsd,
                totalTarjeta = lastShift.TotalTarjeta,
                totalTransferencia = lastShift.TotalTransferencia,
                montoInicialNio = lastShift.MontoInicialNio,
                montoInicialUsd = lastShift.MontoInicialUsd,
                montoContadoNio = lastShift.MontoContadoNio,
                montoContadoUsd = lastShift.MontoContadoUsd,
                montoManualNio = await ShiftService.GetTotalCashEntriesAsync(lastShift.IdTurno, 1),
                montoManualUsd = await ShiftService.GetTotalCashEntriesAsync(lastShift.IdTurno, 2),
                diferenciaNio = lastShift.DiferenciaNio,
                diferenciaUsd = lastShift.DiferenciaUsd,
                observaciones = lastShift.Observaciones
            };

            await JSRuntime.InvokeVoidAsync("qzPrintShiftClosing", printData, configPrint);
            ToastService.ShowSuccess("Reimpresión enviada");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Error al reimprimir: " + ex.Message);
        }
        finally {
            showSelectionModal = false;
        }
    }

    public void Dispose()
    {
        UserSession.OnChange -= StateHasChanged;
        Navigation.LocationChanged -= HandleLocationChanged;
    }

    private bool IsActive(string href)
    {
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        
        // Limpiar parámetros de consulta o fragmentos para la comparación
        int queryIndex = relativePath.IndexOfAny(new[] { '?', '#' });
        if (queryIndex >= 0) relativePath = relativePath.Substring(0, queryIndex);

        if (href == "/") return string.IsNullOrEmpty(relativePath);
        return $"/{relativePath}" == href;
    }

    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
}

