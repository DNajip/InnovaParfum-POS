{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Ejecutar InnovaTecPOS (F5)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/InnovaTecPOS/bin/Debug/net10.0/InnovaTecPOS.dll",
            "args": [],
            "cwd": "${workspaceFolder}/InnovaTecPOS",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5143"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        }
    ]
}
